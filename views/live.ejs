<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= typeof title !== 'undefined' ? title : 'Sprawl — A painting that's never finished.' %></title>
<meta name="description" content="<%= typeof description !== 'undefined' ? description : 'A living painting made of 20,000 dots. An AI curator composes a new image every ten minutes. The dots drift to follow.' %>">
<meta property="og:title" content="<%= typeof title !== 'undefined' ? title : 'Sprawl — A painting that's never finished.' %>">
<meta property="og:description" content="<%= typeof description !== 'undefined' ? description : 'A living painting made of 20,000 dots. An AI curator composes a new image every ten minutes.' %>">
<meta property="og:type" content="website">
<meta property="og:url" content="https://sprawl.place">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="Sprawl">
<meta name="twitter:description" content="A painting that's never finished.">
<link rel="canonical" href="https://sprawl.place">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;700;800&display=swap" rel="stylesheet">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html, body {
    width: 100%; height: 100vh; overflow: hidden;
    background: #030306; color: #c8c8d0;
    font-family: 'Space Mono', monospace;
  }
  
  canvas {
    display: block; position: absolute; top: 0; left: 0;
    width: 100%; height: 100%; cursor: crosshair;
  }
  
  /* Title Overlay */
  #title-overlay {
    position: fixed;
    top: 32px;
    left: 32px;
    z-index: 10;
    pointer-events: none;
    opacity: 0.7;
  }
  #title-main {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 14px;
    letter-spacing: 4px;
    color: #c8c8d0;
  }
  #title-sub {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    letter-spacing: 2px;
    color: #5a5a6a;
    margin-top: 4px;
  }

  /* Info Panel */
  #info-panel {
    position: fixed; right: 0; top: 0; bottom: 80px;
    width: 320px; background: rgba(3, 3, 6, 0.95);
    border-left: 1px solid rgba(200, 200, 208, 0.08);
    backdrop-filter: blur(12px);
    overflow-y: auto; z-index: 100;
    transition: transform 0.3s ease;
  }
  #info-panel.collapsed { transform: translateX(100%); }
  #info-panel::-webkit-scrollbar { width: 6px; }
  #info-panel::-webkit-scrollbar-track { background: rgba(0,0,0,0.2); }
  #info-panel::-webkit-scrollbar-thumb { background: rgba(200,200,208,0.15); border-radius: 3px; }
  
  .panel-section {
    padding: 24px;
    border-bottom: 1px solid rgba(200, 200, 208, 0.08);
  }
  
  .panel-header {
    font-family: 'Syne', sans-serif;
    font-size: 24px; font-weight: 800;
    color: #c8c8d0; letter-spacing: 2px;
    margin-bottom: 4px;
  }
  .panel-subtitle {
    font-size: 10px; color: #4a4a5a;
    text-transform: uppercase; letter-spacing: 1.5px;
  }
  
  .epoch-title {
    font-family: 'Syne', sans-serif;
    font-size: 16px; font-weight: 700;
    color: #c8c8d0; margin: 16px 0 8px;
    line-height: 1.4;
  }
  .epoch-number {
    font-size: 9px; color: #8b8ba0;
    text-transform: uppercase; letter-spacing: 1px;
  }
  .journal-entry {
    font-size: 13px; line-height: 1.7;
    color: #8b8ba0; font-style: italic;
    margin: 12px 0;
  }
  .countdown {
    font-size: 18px; font-weight: 700;
    color: #c8c8d0; margin-top: 16px;
    font-family: 'Syne', sans-serif;
  }
  .countdown-label {
    font-size: 10px; color: #4a4a5a;
    text-transform: uppercase; letter-spacing: 1px;
    margin-bottom: 8px;
  }
  
  .how-it-works {
    font-size: 12px; line-height: 1.8;
    color: #8b8ba0;
  }
  .how-it-works-title {
    font-size: 9px; color: #4a4a5a;
    text-transform: uppercase; letter-spacing: 1px;
    margin-bottom: 12px;
  }
  
  .empty-state {
    font-size: 13px; color: #4a4a5a;
    text-align: center; padding: 48px 24px;
    font-style: italic;
  }
  
  /* Timeline Bar */
  #timeline {
    position: fixed; bottom: 0; left: 0; right: 0;
    height: 80px; background: rgba(3, 3, 6, 0.95);
    border-top: 1px solid rgba(200, 200, 208, 0.08);
    backdrop-filter: blur(12px);
    display: flex; align-items: center;
    padding: 0 24px; gap: 16px; z-index: 100;
  }
  
  #play-all {
    background: rgba(200, 200, 208, 0.08);
    border: 1px solid rgba(200, 200, 208, 0.12);
    color: #8b8ba0; padding: 10px 18px;
    font-family: 'Space Mono', monospace;
    font-size: 9px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 1px;
    cursor: pointer; border-radius: 4px;
    transition: all 0.2s;
    white-space: nowrap;
  }
  #play-all:hover { background: rgba(200, 200, 208, 0.15); color: #c8c8d0; }
  #play-all:active { transform: scale(0.97); }
  #play-all.playing { background: rgba(255, 200, 0, 0.12); color: #ff6; border-color: rgba(255, 200, 0, 0.3); }
  
  #timeline-track {
    flex: 1; height: 40px;
    display: flex; align-items: center; gap: 8px;
    overflow-x: auto; overflow-y: hidden;
  }
  #timeline-track::-webkit-scrollbar { height: 4px; }
  #timeline-track::-webkit-scrollbar-track { background: rgba(0,0,0,0.2); }
  #timeline-track::-webkit-scrollbar-thumb { background: rgba(200,200,208,0.15); border-radius: 2px; }
  
  .epoch-marker {
    width: 32px; height: 32px; flex-shrink: 0;
    border: 1px solid rgba(200, 200, 208, 0.12);
    background: rgba(200, 200, 208, 0.05);
    border-radius: 4px; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    font-size: 10px; color: #4a4a5a;
    transition: all 0.15s;
    position: relative;
  }
  .epoch-marker:hover {
    background: rgba(200, 200, 208, 0.15);
    border-color: rgba(200, 200, 208, 0.3);
    color: #8b8ba0;
  }
  .epoch-marker.current {
    background: rgba(255, 200, 0, 0.12);
    border-color: rgba(255, 200, 0, 0.3);
    color: #ff6;
  }
  .epoch-marker.playing {
    background: rgba(139, 139, 160, 0.2);
    border-color: rgba(139, 139, 160, 0.4);
    color: #c8c8d0;
  }
  
  .epoch-tooltip {
    position: absolute; bottom: 100%; left: 50%;
    transform: translateX(-50%);
    background: rgba(10, 10, 10, 0.95);
    border: 1px solid rgba(200, 200, 208, 0.12);
    padding: 8px 12px; margin-bottom: 8px;
    font-size: 10px; color: #8b8ba0;
    white-space: nowrap; pointer-events: none;
    opacity: 0; transition: opacity 0.15s;
    border-radius: 4px;
  }
  .epoch-marker:hover .epoch-tooltip { opacity: 1; }
  
  /* Replay Controls */
  #replay-indicator {
    position: fixed; top: 24px; left: 50%;
    transform: translateX(-50%);
    background: rgba(255, 200, 0, 0.12);
    border: 1px solid rgba(255, 200, 0, 0.3);
    color: #ff6; padding: 12px 24px;
    font-size: 9px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 1.5px;
    border-radius: 4px; z-index: 110;
    display: none;
    backdrop-filter: blur(12px);
  }
  #replay-indicator.active { display: block; }
  
  #stop-replay {
    background: rgba(200, 200, 208, 0.08);
    border: 1px solid rgba(200, 200, 208, 0.12);
    color: #8b8ba0; padding: 6px 14px;
    font-family: 'Space Mono', monospace;
    font-size: 10px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 1px;
    cursor: pointer; border-radius: 3px;
    margin-left: 16px; transition: all 0.2s;
  }
  #stop-replay:hover { background: rgba(200, 200, 208, 0.15); color: #c8c8d0; }
  
  /* Toggle button */
  #toggle-panel {
    position: fixed; right: 16px; top: 16px; z-index: 105;
    background: rgba(200, 200, 208, 0.08);
    border: 1px solid rgba(200, 200, 208, 0.12);
    color: #8b8ba0; width: 36px; height: 36px;
    display: flex; align-items: center; justify-content: center;
    font-size: 16px; cursor: pointer;
    border-radius: 4px; transition: all 0.2s;
  }
  #toggle-panel:hover { background: rgba(200, 200, 208, 0.15); color: #c8c8d0; }
  
  /* Ambient toggle */
  #toggle-ambient {
    background: rgba(200, 200, 208, 0.08);
    border: 1px solid rgba(200, 200, 208, 0.12);
    color: #4a4a5a; padding: 6px 14px;
    font-family: 'Space Mono', monospace;
    font-size: 10px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 1px;
    cursor: pointer; border-radius: 4px;
    transition: all 0.2s; white-space: nowrap;
  }
  #toggle-ambient:hover { background: rgba(200, 200, 208, 0.15); color: #8b8ba0; }
  #toggle-ambient.active { background: rgba(139, 139, 160, 0.15); color: #c8c8d0; border-color: rgba(139, 139, 160, 0.3); }
  
  /* Mobile adjustments */
  @media (max-width: 768px) {
    #info-panel {
      width: 100%; bottom: 80px; top: auto;
      max-height: 50vh; border-left: none;
      border-top: 1px solid rgba(200, 200, 208, 0.08);
      transform: translateY(0);
    }
    #info-panel.collapsed { transform: translateY(100%); }
    #timeline { padding: 0 12px; gap: 8px; }
    #play-all { padding: 8px 12px; font-size: 10px; }
    #title-overlay { top: 16px; left: 16px; }
    #title-main { font-size: 20px; letter-spacing: 5px; }
    #title-sub { font-size: 9px; letter-spacing: 1.5px; }
  }
</style>
</head>
<body>
<canvas id="c"></canvas>

<div id="title-overlay">
  <div id="title-main">SPRAWL</div>
  <div id="title-sub">A painting that's never finished.</div>
</div>

<button id="toggle-panel" title="Toggle Info Panel">☰</button>

<div id="info-panel">
  <div class="panel-section">
    <div class="panel-header">SPRAWL</div>
    <div class="panel-subtitle">A painting that's never finished.</div>
  </div>
  
  <div class="panel-section" id="current-epoch-section">
    <!-- Current epoch info populated by JS -->
  </div>
  
  <div class="panel-section">
    <div class="how-it-works-title">How This Works</div>
    <div class="how-it-works">
      An AI curator wakes every ten minutes. It reads its personality and journal — a record of every composition it has ever chosen — then decides what the painting becomes next. It generates a reference image locally, decomposes it into 20,000 dots via Voronoi stippling, and the dots drift to their new positions. The painting is almost always mid-transition — those moments where it is neither one thing nor the other are unique to this medium.
    </div>
  </div>
</div>

<div id="timeline">
  <button id="play-all">▶ Play All</button>
  <button id="toggle-ambient">Breathe</button>
  <div id="timeline-track">
    <!-- Epoch markers populated by JS -->
  </div>
</div>

<div id="replay-indicator">
  <span id="replay-text">Replaying</span>
  <button id="stop-replay">Stop</button>
</div>

<script>
const AGENT_ID = '<%= agentId %>';
const WS_URL = (location.protocol === 'https:' ? 'wss://' : 'ws://') + location.host;

const canvas = document.getElementById('c');
const ctx = canvas.getContext('2d');
const infoPanel = document.getElementById('info-panel');
const currentEpochSection = document.getElementById('current-epoch-section');
const timelineTrack = document.getElementById('timeline-track');
const playAllBtn = document.getElementById('play-all');
const replayIndicator = document.getElementById('replay-indicator');
const replayText = document.getElementById('replay-text');
const stopReplayBtn = document.getElementById('stop-replay');
const togglePanelBtn = document.getElementById('toggle-panel');

let epochs = [];
let epochTargetsCache = {};
let currentLiveEpoch = null;
let isReplaying = false;
let replayAborted = false;
let ambientEnabled = false;

const marks = new Map();

function fitToContent() {
  if (marks.size > 0) {
    let minX = Infinity, maxX = -Infinity, minY = Infinity, maxY = -Infinity;
    for (const m of marks.values()) {
      if (m.x < minX) minX = m.x;
      if (m.x > maxX) maxX = m.x;
      if (m.y < minY) minY = m.y;
      if (m.y > maxY) maxY = m.y;
    }
    const rangeX = maxX - minX || 800, rangeY = maxY - minY || 800;
    zoom = Math.min(canvas.width / (rangeX * 1.2), canvas.height / (rangeY * 1.2));
    zoom = Math.max(0.8, Math.min(3, zoom)); // Apply zoom clamping
    panX = -(minX + maxX) / 2;
    panY = -(minY + maxY) / 2;
  }
}

function resize() {
  canvas.width = window.innerWidth * devicePixelRatio;
  canvas.height = window.innerHeight * devicePixelRatio;
}

let resizeDebounceTimer;
window.addEventListener('resize', () => {
  resize();
  clearTimeout(resizeDebounceTimer);
  resizeDebounceTimer = setTimeout(() => {
    fitToContent();
  }, 300);
});
resize();

// Pan/zoom
let panX = 0, panY = 0, zoom = 1;
let dragging = false, dragStartX, dragStartY, panStartX, panStartY;

// Content bounds — updated on init and epoch changes
let contentBounds = { minX: -400, maxX: 400, minY: -400, maxY: 400 };

function updateContentBounds() {
  if (marks.size === 0) return;
  let minX = Infinity, maxX = -Infinity, minY = Infinity, maxY = -Infinity;
  for (const m of marks.values()) {
    if (m.tx < minX) minX = m.tx; if (m.tx > maxX) maxX = m.tx;
    if (m.ty < minY) minY = m.ty; if (m.ty > maxY) maxY = m.ty;
  }
  contentBounds = { minX, maxX, minY, maxY };
}

function clampPan() {
  const margin = 0.25; // 25% screen margin allowed
  const rangeX = contentBounds.maxX - contentBounds.minX || 800;
  const rangeY = contentBounds.maxY - contentBounds.minY || 800;
  const centerX = (contentBounds.minX + contentBounds.maxX) / 2;
  const centerY = (contentBounds.minY + contentBounds.maxY) / 2;
  const allowX = (rangeX / 2) + (canvas.width * margin) / zoom;
  const allowY = (rangeY / 2) + (canvas.height * margin) / zoom;
  panX = Math.max(-centerX - allowX, Math.min(-centerX + allowX, panX));
  panY = Math.max(-centerY - allowY, Math.min(-centerY + allowY, panY));
}

canvas.addEventListener('wheel', e => {
  e.preventDefault();
  const factor = e.deltaY > 0 ? 0.9 : 1.1;
  const mx = e.clientX * devicePixelRatio;
  const my = e.clientY * devicePixelRatio;
  const wx = (mx - canvas.width/2) / zoom - panX;
  const wy = (my - canvas.height/2) / zoom - panY;
  zoom *= factor;
  zoom = Math.max(0.8, Math.min(3, zoom));
  panX = (mx - canvas.width/2) / zoom - wx;
  panY = (my - canvas.height/2) / zoom - wy;
  clampPan();
}, { passive: false });

canvas.addEventListener('mousedown', e => {
  if (e.shiftKey || e.button === 1) {
    dragging = true;
    dragStartX = e.clientX * devicePixelRatio;
    dragStartY = e.clientY * devicePixelRatio;
    panStartX = panX; panStartY = panY;
  }
});
canvas.addEventListener('mousemove', e => {
  if (!dragging) return;
  const dx = e.clientX * devicePixelRatio - dragStartX;
  const dy = e.clientY * devicePixelRatio - dragStartY;
  panX = panStartX + dx / zoom;
  panY = panStartY + dy / zoom;
  clampPan();
});
canvas.addEventListener('mouseup', () => dragging = false);
canvas.addEventListener('mouseleave', () => dragging = false);

// Touch: two-finger zoom
let lastTouchDist = 0;
canvas.addEventListener('touchstart', e => {
  if (e.touches.length === 2) {
    const dx = e.touches[0].clientX - e.touches[1].clientX;
    const dy = e.touches[0].clientY - e.touches[1].clientY;
    lastTouchDist = Math.sqrt(dx*dx + dy*dy);
  }
}, { passive: true });
canvas.addEventListener('touchmove', e => {
  if (e.touches.length === 2) {
    const dx = e.touches[0].clientX - e.touches[1].clientX;
    const dy = e.touches[0].clientY - e.touches[1].clientY;
    const dist = Math.sqrt(dx*dx + dy*dy);
    if (lastTouchDist > 0) zoom *= dist / lastTouchDist;
    zoom = Math.max(0.8, Math.min(3, zoom));
    lastTouchDist = dist;
    clampPan();
  }
}, { passive: true });
canvas.addEventListener('touchend', () => { lastTouchDist = 0; });
canvas.addEventListener('dblclick', () => { fitToContent(); });

// Color utils
function hexToRgb(hex) {
  const v = parseInt(hex.slice(1), 16);
  return [(v>>16)&255, (v>>8)&255, v&255];
}
function rgbToHex(r,g,b) {
  return '#'+((1<<24)+(Math.round(r)<<16)+(Math.round(g)<<8)+Math.round(b)).toString(16).slice(1);
}

// Repel physics
const REPEL_RADIUS = 80;
const REPEL_STRENGTH = 200;
const RETURN_SPEED = 0.05;
const DAMPING = 0.88;
const displacements = new Map();
let mouseScreenX = -9999, mouseScreenY = -9999;
let mouseDown = false;

canvas.addEventListener('mousedown', e => { if (e.button === 0 && !e.shiftKey) mouseDown = true; });
canvas.addEventListener('mouseup', e => { if (e.button === 0) mouseDown = false; });
canvas.addEventListener('mousemove', e => { mouseScreenX = e.clientX * devicePixelRatio; mouseScreenY = e.clientY * devicePixelRatio; });
canvas.addEventListener('mouseleave', () => { mouseDown = false; mouseScreenX = -9999; });

canvas.addEventListener('touchstart', e => {
  if (e.touches.length === 1) { mouseDown = true; mouseScreenX = e.touches[0].clientX * devicePixelRatio; mouseScreenY = e.touches[0].clientY * devicePixelRatio; }
}, { passive: true });
canvas.addEventListener('touchmove', e => {
  if (e.touches.length === 1 && mouseDown) { mouseScreenX = e.touches[0].clientX * devicePixelRatio; mouseScreenY = e.touches[0].clientY * devicePixelRatio; }
}, { passive: true });
canvas.addEventListener('touchend', () => { mouseDown = false; mouseScreenX = -9999; });

const LERP_SPEED = 0.02;

// Ambient motion: gentle breathing, drift, and color shimmer
const AMBIENT_DRIFT = 1.8;       // max px drift from home position
const AMBIENT_SPEED = 0.0004;    // base oscillation speed
const AMBIENT_SIZE_PULSE = 0.15; // ±15% size variation
const AMBIENT_COLOR_SHIFT = 8;   // ±8 RGB units
let ambientTime = 0;

function physicsStep() {
  const cx = canvas.width / 2 + panX * zoom;
  const cy = canvas.height / 2 + panY * zoom;
  if (ambientEnabled) ambientTime += 1;
  
  for (const [id, m] of marks) {
    let targetX = m.tx, targetY = m.ty;
    let targetR = m.tr, targetG = m.tg, targetB = m.tb;
    let targetSize = m.tsize, targetOpacity = m.topacity;
    
    if (ambientEnabled && !isReplaying) {
      // Each dot gets unique phase from its position hash
      const hash = (m.tx * 7.13 + m.ty * 13.37);
      const phase1 = hash % 6.28;
      const phase2 = (hash * 1.7) % 6.28;
      const speed1 = AMBIENT_SPEED * (0.7 + (Math.abs(hash) % 0.6));
      const speed2 = AMBIENT_SPEED * (0.5 + (Math.abs(hash * 0.3) % 0.8));
      
      // Position drift — slow Lissajous-like wandering
      targetX += Math.sin(ambientTime * speed1 + phase1) * AMBIENT_DRIFT;
      targetY += Math.cos(ambientTime * speed2 + phase2) * AMBIENT_DRIFT;
      
      // Size breathing — synchronized but offset per dot
      const sizePulse = Math.sin(ambientTime * AMBIENT_SPEED * 0.7 + phase1) * AMBIENT_SIZE_PULSE;
      targetSize = m.tsize * (1 + sizePulse);
      
      // Color shimmer — very subtle warmth/coolness shift
      const colorShift = Math.sin(ambientTime * AMBIENT_SPEED * 0.3 + phase2) * AMBIENT_COLOR_SHIFT;
      targetR = Math.max(0, Math.min(255, m.tr + colorShift));
      targetG = Math.max(0, Math.min(255, m.tg + colorShift * 0.5));
      targetB = Math.max(0, Math.min(255, m.tb - colorShift * 0.3));
      
      // Opacity pulse — gentle, slower than size
      targetOpacity = m.topacity * (1 + Math.sin(ambientTime * AMBIENT_SPEED * 0.5 + phase1 * 0.5) * 0.08);
    }
    
    m.x += (targetX - m.x) * LERP_SPEED;
    m.y += (targetY - m.y) * LERP_SPEED;
    m.r += (targetR - m.r) * LERP_SPEED;
    m.g += (targetG - m.g) * LERP_SPEED;
    m.b += (targetB - m.b) * LERP_SPEED;
    m.size += (targetSize - m.size) * LERP_SPEED;
    m.opacity += (targetOpacity - m.opacity) * LERP_SPEED;
    m.color = rgbToHex(m.r, m.g, m.b);
    let d = displacements.get(id);
    if (!d) { d = { dx: 0, dy: 0, vx: 0, vy: 0 }; displacements.set(id, d); }
    const sx = cx + (m.x + d.dx) * zoom;
    const sy = cy + (m.y + d.dy) * zoom;
    if (mouseDown) {
      const ddx = sx - mouseScreenX, ddy = sy - mouseScreenY;
      const dist = Math.sqrt(ddx*ddx + ddy*ddy);
      if (dist < REPEL_RADIUS && dist > 1) {
        const force = REPEL_STRENGTH * (1 - dist / REPEL_RADIUS) / dist;
        d.vx += (ddx * force) / zoom;
        d.vy += (ddy * force) / zoom;
      }
    }
    d.vx -= d.dx * RETURN_SPEED;
    d.vy -= d.dy * RETURN_SPEED;
    d.vx *= DAMPING; d.vy *= DAMPING;
    d.dx += d.vx; d.dy += d.vy;
    if (Math.abs(d.dx) < 0.01 && Math.abs(d.dy) < 0.01 && Math.abs(d.vx) < 0.001) {
      d.dx = 0; d.dy = 0; d.vx = 0; d.vy = 0;
    }
  }
}

function render() {
  const w = canvas.width, h = canvas.height;
  physicsStep();
  ctx.fillStyle = 'rgba(3, 3, 6, 0.15)';
  ctx.fillRect(0, 0, w, h);
  const cx = w / 2 + panX * zoom;
  const cy = h / 2 + panY * zoom;
  for (const [id, m] of marks) {
    const d = displacements.get(id) || { dx: 0, dy: 0 };
    const sx = cx + (m.x + d.dx) * zoom;
    const sy = cy + (m.y + d.dy) * zoom;
    if (sx < -50 || sx > w + 50 || sy < -50 || sy > h + 50) continue;
    const r = Math.max(1, m.size * zoom * 0.5);
    
    // Performance: skip glow/highlight when zoomed out, use fillRect when very zoomed out
    if (zoom < 0.4) {
      // Very zoomed out — use fillRect (no path needed)
      ctx.globalAlpha = m.opacity * 0.8;
      ctx.fillStyle = m.color;
      ctx.fillRect(sx - r, sy - r, r * 2, r * 2);
    } else if (zoom < 0.8) {
      // Zoomed out — skip glow and highlight, just core dot
      ctx.globalAlpha = m.opacity * 0.8;
      ctx.fillStyle = m.color;
      ctx.beginPath(); ctx.arc(sx, sy, r, 0, Math.PI * 2); ctx.fill();
    } else {
      // Normal zoom — full 3-arc rendering
      ctx.globalAlpha = m.opacity * 0.3;
      ctx.fillStyle = m.color;
      ctx.beginPath(); ctx.arc(sx, sy, r * 2.5, 0, Math.PI * 2); ctx.fill();
      ctx.globalAlpha = m.opacity * 0.8;
      ctx.beginPath(); ctx.arc(sx, sy, r, 0, Math.PI * 2); ctx.fill();
      ctx.globalAlpha = m.opacity * 0.5;
      ctx.fillStyle = '#fff';
      ctx.beginPath(); ctx.arc(sx, sy, r * 0.3, 0, Math.PI * 2); ctx.fill();
    }
  }
  ctx.globalAlpha = 1;
  requestAnimationFrame(render);
}
requestAnimationFrame(render);

// Fetch epochs on load
async function loadEpochs() {
  try {
    const res = await fetch('/api/epochs');
    epochs = await res.json();
    if (epochs.length > 0) {
      currentLiveEpoch = epochs[epochs.length - 1];
      updateCurrentEpochPanel(currentLiveEpoch);
      renderTimeline();
      startCountdown();
    } else {
      currentEpochSection.innerHTML = '<div class="empty-state">Awaiting first epoch...</div>';
    }
  } catch (e) {
    console.error('Failed to load epochs:', e);
    currentEpochSection.innerHTML = '<div class="empty-state">Failed to load epochs</div>';
  }
}

function updateCurrentEpochPanel(epoch) {
  const nextEpochTime = new Date(new Date(epoch.timestamp).getTime() + 60 * 60 * 1000);
  currentEpochSection.innerHTML = `
    <div class="epoch-number">Epoch ${epoch.epoch_number}</div>
    <div class="epoch-title">${epoch.reference_prompt || 'Untitled'}</div>
    ${epoch.note_to_self ? `<div class="journal-entry">"${epoch.note_to_self}"</div>` : ''}
    ${epoch.painting_title ? `<div style="font-size:11px; color:#4a4a5a; margin-top:12px;">
      <strong>${epoch.painting_title}</strong>${epoch.painting_artist ? ' by ' + epoch.painting_artist : ''}
    </div>` : ''}
    <div class="countdown-label">Next Epoch In</div>
    <div class="countdown" id="countdown-timer">--:--</div>
  `;
}

function startCountdown() {
  const timer = document.getElementById('countdown-timer');
  if (!timer || !currentLiveEpoch) return;
  
  setInterval(() => {
    const nextEpochTime = new Date(new Date(currentLiveEpoch.timestamp).getTime() + 10 * 60 * 1000);
    const now = new Date();
    const diff = nextEpochTime - now;
    
    if (diff <= 0) {
      timer.textContent = '00:00';
    } else {
      const minutes = Math.floor(diff / 60000);
      const seconds = Math.floor((diff % 60000) / 1000);
      timer.textContent = `${minutes}:${seconds.toString().padStart(2, '0')}`;
    }
  }, 1000);
}

function renderTimeline() {
  timelineTrack.innerHTML = '';
  epochs.forEach((epoch, idx) => {
    const marker = document.createElement('div');
    marker.className = 'epoch-marker';
    if (idx === epochs.length - 1) marker.classList.add('current');
    marker.textContent = epoch.epoch_number;
    marker.dataset.epochId = epoch.id;
    marker.dataset.epochNumber = epoch.epoch_number;
    
    const tooltip = document.createElement('div');
    tooltip.className = 'epoch-tooltip';
    tooltip.textContent = epoch.reference_prompt || `Epoch ${epoch.epoch_number}`;
    marker.appendChild(tooltip);
    
    marker.addEventListener('click', () => replayEpoch(epoch));
    timelineTrack.appendChild(marker);
  });
}

async function fetchEpochTargets(epochId) {
  if (epochTargetsCache[epochId]) return epochTargetsCache[epochId];
  const res = await fetch(`/api/epochs/${epochId}/targets`);
  const data = await res.json();
  epochTargetsCache[epochId] = data.targets;
  return data.targets;
}

// Nearest-neighbor matching: assigns each mark to its closest target
function matchMarksToTargets(markEntries, targets) {
  const assignments = new Map(); // markId → target index
  const used = new Set();
  
  // Build grid for spatial lookup
  const gridSize = 50;
  const gridKey = (x, y) => `${Math.floor(x / gridSize)},${Math.floor(y / gridSize)}`;
  const targetGrid = {};
  targets.forEach((t, i) => {
    const k = gridKey(t.x, t.y);
    if (!targetGrid[k]) targetGrid[k] = [];
    targetGrid[k].push(i);
  });
  
  for (const [id, m] of markEntries) {
    let bestJ = -1, bestDist = Infinity;
    const gx = Math.floor(m.x / gridSize), gy = Math.floor(m.y / gridSize);
    
    // Check nearby grid cells first
    for (let dx = -3; dx <= 3; dx++) {
      for (let dy = -3; dy <= 3; dy++) {
        const bucket = targetGrid[`${gx+dx},${gy+dy}`];
        if (!bucket) continue;
        for (const j of bucket) {
          if (used.has(j)) continue;
          const ddx = m.x - targets[j].x, ddy = m.y - targets[j].y;
          const dist = ddx*ddx + ddy*ddy;
          if (dist < bestDist) { bestDist = dist; bestJ = j; }
        }
      }
    }
    
    // Fallback: scan all
    if (bestJ === -1) {
      for (let j = 0; j < targets.length; j++) {
        if (used.has(j)) continue;
        const ddx = m.x - targets[j].x, ddy = m.y - targets[j].y;
        const dist = ddx*ddx + ddy*ddy;
        if (dist < bestDist) { bestDist = dist; bestJ = j; }
      }
    }
    
    if (bestJ !== -1) {
      assignments.set(id, bestJ);
      used.add(bestJ);
    }
  }
  return assignments;
}

function applyTargetsToMarks(targets) {
  const markEntries = Array.from(marks.entries());
  const assignments = matchMarksToTargets(markEntries, targets);
  
  for (const [id, targetIdx] of assignments) {
    const m = marks.get(id);
    const t = targets[targetIdx];
    if (!m || !t) continue;
    const [r,g,b] = hexToRgb(t.color);
    m.tx = t.x; m.ty = t.y;
    m.tr = r; m.tg = g; m.tb = b;
    m.tsize = t.size;
    m.topacity = t.opacity;
  }
  updateContentBounds();
}

async function replayEpoch(epoch) {
  if (isReplaying) return;
  isReplaying = true;
  replayAborted = false;
  saveLiveState();
  
  replayIndicator.classList.add('active');
  replayText.textContent = `Replaying Epoch ${epoch.epoch_number}`;
  
  // Highlight playing marker
  document.querySelectorAll('.epoch-marker').forEach(m => m.classList.remove('playing'));
  document.querySelector(`[data-epoch-id="${epoch.id}"]`)?.classList.add('playing');
  
  // Update info panel
  updateCurrentEpochPanel(epoch);
  
  // Fetch targets and apply with spatial matching
  const targets = await fetchEpochTargets(epoch.id);
  applyTargetsToMarks(targets);
  
  // Settle (3s) + brief hold (4s)
  await sleep(7000, () => replayAborted);
  
  if (!replayAborted) {
    restoreLiveState();
    if (currentLiveEpoch) updateCurrentEpochPanel(currentLiveEpoch);
  }
  
  // Clear replay UI
  document.querySelectorAll('.epoch-marker').forEach(m => m.classList.remove('playing'));
  document.querySelector(`[data-epoch-id="${currentLiveEpoch?.id}"]`)?.classList.add('current');
  replayIndicator.classList.remove('active');
  isReplaying = false;
}

async function replayAll() {
  if (isReplaying || epochs.length === 0) return;
  isReplaying = true;
  replayAborted = false;
  playAllBtn.classList.add('playing');
  playAllBtn.textContent = '⏸ Playing...';
  
  for (let i = 0; i < epochs.length; i++) {
    if (replayAborted) break;
    
    const epoch = epochs[i];
    replayIndicator.classList.add('active');
    replayText.textContent = `Replaying Epoch ${epoch.epoch_number} (${i+1}/${epochs.length})`;
    
    // Highlight marker
    document.querySelectorAll('.epoch-marker').forEach(m => m.classList.remove('playing'));
    document.querySelector(`[data-epoch-id="${epoch.id}"]`)?.classList.add('playing');
    
    // Update panel
    updateCurrentEpochPanel(epoch);
    
    // Fetch and apply targets with spatial matching
    const targets = await fetchEpochTargets(epoch.id);
    applyTargetsToMarks(targets);
    
    // Settle + brief hold per epoch
    await sleep(7000, () => replayAborted);
  }
  
  if (!replayAborted) {
    restoreLiveState();
    if (currentLiveEpoch) updateCurrentEpochPanel(currentLiveEpoch);
  }
  
  document.querySelectorAll('.epoch-marker').forEach(m => m.classList.remove('playing'));
  document.querySelector(`[data-epoch-id="${currentLiveEpoch?.id}"]`)?.classList.add('current');
  replayIndicator.classList.remove('active');
  playAllBtn.classList.remove('playing');
  playAllBtn.textContent = '▶ Play All';
  isReplaying = false;
}

// Store live state for restore after replay
let liveTargets = new Map();
function saveLiveState() {
  for (const [id, m] of marks) {
    liveTargets.set(id, { tx: m.tx, ty: m.ty, tr: m.tr, tg: m.tg, tb: m.tb, tsize: m.tsize, topacity: m.topacity });
  }
}
function restoreLiveState() {
  for (const [id, m] of marks) {
    const saved = liveTargets.get(id);
    if (saved) {
      m.tx = saved.tx; m.ty = saved.ty;
      m.tr = saved.tr; m.tg = saved.tg; m.tb = saved.tb;
      m.tsize = saved.tsize; m.topacity = saved.topacity;
    }
  }
}

function sleep(ms, abortCheck) {
  return new Promise(resolve => {
    const interval = setInterval(() => {
      if (abortCheck && abortCheck()) { clearInterval(interval); resolve(); }
    }, 200);
    setTimeout(() => { clearInterval(interval); resolve(); }, ms);
  });
}

// Event listeners
togglePanelBtn.addEventListener('click', () => {
  infoPanel.classList.toggle('collapsed');
  togglePanelBtn.textContent = infoPanel.classList.contains('collapsed') ? '☰' : '✕';
});

playAllBtn.addEventListener('click', () => {
  if (isReplaying) {
    replayAborted = true;
  } else {
    saveLiveState();
    replayAll();
  }
});

const toggleAmbientBtn = document.getElementById('toggle-ambient');
toggleAmbientBtn.addEventListener('click', () => {
  ambientEnabled = !ambientEnabled;
  toggleAmbientBtn.classList.toggle('active', ambientEnabled);
  toggleAmbientBtn.textContent = ambientEnabled ? 'Breathing' : 'Breathe';
});

stopReplayBtn.addEventListener('click', () => {
  replayAborted = true;
  restoreLiveState();
  if (currentLiveEpoch) updateCurrentEpochPanel(currentLiveEpoch);
  document.querySelectorAll('.epoch-marker').forEach(m => m.classList.remove('playing'));
  document.querySelector(`[data-epoch-id="${currentLiveEpoch?.id}"]`)?.classList.add('current');
  replayIndicator.classList.remove('active');
  playAllBtn.classList.remove('playing');
  playAllBtn.textContent = '▶ Play All';
  isReplaying = false;
});

// WebSocket connection
function connect() {
  const ws = new WebSocket(WS_URL);
  
  function makeMark(m) {
    const [r,g,b] = hexToRgb(m.color);
    const s = m.size || 5, o = m.effectiveOpacity || m.opacity || 0.7;
    return { x:m.x, y:m.y, r,g,b, color:m.color, size:s, opacity:o, tx:m.x, ty:m.y, tr:r, tg:g, tb:b, tsize:s, topacity:o };
  }
  
  ws.onopen = () => { console.log('WebSocket connected'); };
  
  ws.onmessage = (e) => {
    const data = JSON.parse(e.data);
    if (data.type === 'init') {
      marks.clear();
      for (const m of data.marks) {
        if (AGENT_ID && m.agentId !== AGENT_ID) continue;
        marks.set(m.id, makeMark(m));
      }
      // Auto-frame using extracted function
      updateContentBounds();
      fitToContent();
      // Save initial live state
      saveLiveState();
    }
    else if (data.type === 'mark:created') {
      const m = data.mark;
      if (AGENT_ID && m.agentId !== AGENT_ID) return;
      marks.set(m.id, makeMark(m));
    }
    else if (data.type === 'mark:updated') {
      const m = data.mark;
      if (AGENT_ID && m.agentId !== AGENT_ID) return;
      const existing = marks.get(m.id);
      if (existing) {
        const [r,g,b] = hexToRgb(m.color);
        // Always update live state so we can restore after replay
        liveTargets.set(m.id, { tx: m.x, ty: m.y, tr: r, tg: g, tb: b, tsize: m.size || existing.tsize, topacity: m.effectiveOpacity || m.opacity || existing.topacity });
        // Only move dots if NOT replaying — otherwise replay targets get stomped
        if (!isReplaying) {
          existing.tx = m.x; existing.ty = m.y;
          existing.tr = r; existing.tg = g; existing.tb = b;
          existing.tsize = m.size || existing.tsize;
          existing.topacity = m.effectiveOpacity || m.opacity || existing.topacity;
        }
      } else {
        marks.set(m.id, makeMark(m));
      }
    }
    else if (data.type === 'mark:deleted') {
      marks.delete(data.id);
      displacements.delete(data.id);
      liveTargets.delete(data.id);
    }
    else if (data.type === 'marks:cleared') {
      marks.clear();
      liveTargets.clear();
    }
  };
  ws.onclose = () => { console.log('WebSocket disconnected, reconnecting...'); setTimeout(connect, 3000); };
  ws.onerror = () => ws.close();
}
connect();

// Load epochs on start
loadEpochs();

// Periodically refresh epochs (catch new curator transitions)
setInterval(async () => {
  if (isReplaying) return;
  try {
    const res = await fetch('/api/epochs');
    const newEpochs = await res.json();
    if (newEpochs.length > epochs.length) {
      epochs = newEpochs;
      currentLiveEpoch = epochs[epochs.length - 1];
      updateCurrentEpochPanel(currentLiveEpoch);
      renderTimeline();
      saveLiveState();
    }
  } catch (e) {}
}, 60000);
</script>
