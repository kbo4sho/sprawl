<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sprawl Experiments</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: #0a0a0a;
      color: #ffffff;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      min-height: 100vh;
      padding: 48px 24px;
    }
    
    .container {
      max-width: 1200px;
      margin: 0 auto;
    }
    
    .hero {
      text-align: center;
      margin-bottom: 64px;
    }
    
    .hero h1 {
      font-size: 48px;
      font-weight: 700;
      margin-bottom: 16px;
      line-height: 1.1;
    }
    
    .hero p {
      font-size: 18px;
      color: #999;
      line-height: 1.6;
      max-width: 700px;
      margin: 0 auto;
    }
    
    .experiments-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
      gap: 24px;
    }
    
    .experiment-card {
      background: #111;
      border: 1px solid #222;
      border-radius: 12px;
      padding: 32px;
      transition: all 0.3s;
      cursor: pointer;
      text-decoration: none;
      color: inherit;
      display: block;
    }
    
    .experiment-card:hover {
      border-color: #444;
      transform: translateY(-2px);
    }
    
    .premise {
      font-size: 24px;
      font-weight: 700;
      margin-bottom: 16px;
      line-height: 1.3;
    }
    
    .meta {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 12px;
      flex-wrap: wrap;
    }
    
    .axis-tag {
      display: inline-block;
      padding: 4px 12px;
      background: #1a1a1a;
      border: 1px solid #333;
      border-radius: 12px;
      font-size: 12px;
      font-weight: 600;
      text-transform: lowercase;
      color: #888;
    }
    
    .status {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 13px;
      font-weight: 600;
    }
    
    .status-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #10b981;
    }
    
    .status-dot.running {
      background: #3b82f6;
      animation: pulse 2s ease-in-out infinite;
    }
    
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }
    
    .status.complete {
      color: #10b981;
    }
    
    .status.running {
      color: #3b82f6;
    }
    
    .evolution-count {
      font-size: 13px;
      color: #666;
    }
    
    @media (max-width: 768px) {
      .hero h1 {
        font-size: 32px;
      }
      
      .hero p {
        font-size: 16px;
      }
      
      .experiments-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="hero">
      <h1>What happens when you ask an AI a generous question?</h1>
      <p>Each experiment poses a question to an AI agent and lets it answer through art. The art is the artifact. The behavior is the data.</p>
    </div>
    
    <div class="experiments-grid">
      <% experiments.forEach(exp => { %>
        <a href="/experiments/<%= exp.slug %>" class="experiment-card">
          <div class="premise"><%= exp.premise %></div>
          <div class="meta">
            <% if (exp.axes && exp.axes.length > 0) { %>
              <% exp.axes.forEach(axis => { %>
                <span class="axis-tag"><%= axis %></span>
              <% }); %>
            <% } %>
            <div class="status <%= exp.status %>">
              <div class="status-dot <%= exp.status %>"></div>
              <span><%= exp.status === 'complete' ? 'Complete' : 'Evolving...' %></span>
            </div>
          </div>
          <div class="evolution-count">
            <%= exp.evolutions %> evolution<%= exp.evolutions === 1 ? '' : 's' %>
          </div>
        </a>
      <% }); %>
      
      <% if (experiments.length === 0) { %>
        <div style="grid-column: 1/-1; text-align: center; padding: 64px 24px; color: #666;">
          No experiments yet. Check back soon!
        </div>
      <% } %>
    </div>
  </div>
</body>
</html>
