<%- include('partials/head') %>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    background: #0a0a0a;
    color: #ffffff;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    min-height: 100vh;
  }
  
  .canvas-page {
    max-width: 1400px;
    margin: 0 auto;
    padding: 24px;
  }
  
  /* Header */
  .page-header {
    margin-bottom: 32px;
  }
  
  .back-link {
    display: inline-block;
    font-size: 12px;
    color: #666;
    text-decoration: none;
    margin-bottom: 16px;
    transition: color 0.2s;
  }
  
  .back-link:hover {
    color: #999;
  }
  
  .canvas-title {
    font-size: 36px;
    font-weight: 700;
    margin-bottom: 8px;
  }
  
  .canvas-meta {
    display: flex;
    gap: 24px;
    font-size: 14px;
    color: #888;
  }
  
  .canvas-meta .stat {
    display: flex;
    gap: 6px;
  }
  
  .canvas-meta .value {
    color: #ccc;
    font-weight: 600;
  }
  
  /* Canvas view area */
  .canvas-viewer {
    background: #111;
    border: 1px solid #222;
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 24px;
    position: relative;
  }
  
  .canvas-viewer .view-toggle {
    position: absolute;
    top: 16px;
    right: 16px;
    z-index: 10;
    display: flex;
    gap: 8px;
    background: rgba(0,0,0,0.8);
    backdrop-filter: blur(10px);
    padding: 4px;
    border-radius: 6px;
    border: 1px solid #333;
  }
  
  .canvas-viewer .view-toggle button {
    padding: 8px 16px;
    font-size: 12px;
    background: transparent;
    color: #888;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.2s;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
  }
  
  .canvas-viewer .view-toggle button.active {
    background: #2a2a2a;
    color: #fff;
  }
  
  .canvas-viewer .view-toggle button:hover:not(.active) {
    color: #aaa;
  }
  
  .canvas-content {
    aspect-ratio: 1;
    max-height: 600px;
    position: relative;
  }
  
  #rendered-view {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: none;
  }
  
  #rendered-view.active {
    display: block;
  }
  
  #live-view {
    width: 100%;
    height: 100%;
    display: none;
  }
  
  #live-view.active {
    display: block;
  }
  
  .no-render-message {
    display: none;
    align-items: center;
    justify-content: center;
    height: 100%;
    color: #666;
    font-size: 14px;
  }
  
  .no-render-message.active {
    display: flex;
  }
  
  /* Actions */
  .canvas-actions {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 24px;
    margin-bottom: 48px;
  }
  
  .contribute-card {
    background: #111;
    border: 1px solid #222;
    border-radius: 8px;
    padding: 24px;
  }
  
  .contribute-card h3 {
    font-size: 18px;
    margin-bottom: 16px;
  }
  
  .contribute-card p {
    font-size: 14px;
    color: #888;
    margin-bottom: 20px;
    line-height: 1.5;
  }
  
  .contribute-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  
  .contribute-form input {
    padding: 12px;
    background: #1a1a1a;
    border: 1px solid #333;
    border-radius: 6px;
    color: #fff;
    font-size: 14px;
    font-family: 'Inter', sans-serif;
  }
  
  .contribute-form input::placeholder {
    color: #555;
  }
  
  .contribute-form button {
    padding: 14px 24px;
    background: #fff;
    color: #000;
    border: none;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
    font-family: 'Inter', sans-serif;
  }
  
  .contribute-form button:hover {
    background: #eee;
  }
  
  .contribute-form button:disabled {
    background: #333;
    color: #666;
    cursor: not-allowed;
  }
  
  .progress-card {
    background: #111;
    border: 1px solid #222;
    border-radius: 8px;
    padding: 24px;
  }
  
  .progress-card h3 {
    font-size: 14px;
    color: #888;
    margin-bottom: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  
  .progress-bar {
    height: 8px;
    background: #222;
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 8px;
  }
  
  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #4a9eff, #6ab4ff);
    transition: width 0.3s;
  }
  
  .progress-label {
    font-size: 12px;
    color: #666;
  }
  
  /* Contributors & Renders */
  .canvas-info {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-bottom: 48px;
  }
  
  .info-section {
    background: #111;
    border: 1px solid #222;
    border-radius: 8px;
    padding: 24px;
  }
  
  .info-section h3 {
    font-size: 16px;
    margin-bottom: 16px;
    color: #ccc;
  }
  
  .contributor-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    max-height: 300px;
    overflow-y: auto;
  }
  
  .contributor-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 0;
    border-bottom: 1px solid #1a1a1a;
    font-size: 13px;
  }
  
  .contributor-item:last-child {
    border-bottom: none;
  }
  
  .contributor-email {
    color: #aaa;
  }
  
  .contributor-time {
    color: #555;
    font-size: 11px;
  }
  
  .render-gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
    gap: 8px;
  }
  
  .render-thumbnail {
    aspect-ratio: 1;
    border-radius: 4px;
    overflow: hidden;
    cursor: pointer;
    border: 2px solid transparent;
    transition: border-color 0.2s;
  }
  
  .render-thumbnail:hover {
    border-color: #4a9eff;
  }
  
  .render-thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .empty-state {
    text-align: center;
    padding: 40px 20px;
    color: #555;
    font-size: 13px;
  }
  
  @media (max-width: 768px) {
    .canvas-actions {
      grid-template-columns: 1fr;
    }
    
    .canvas-info {
      grid-template-columns: 1fr;
    }
    
    .canvas-title {
      font-size: 24px;
    }
  }
</style>

<div class="canvas-page">
  <div class="page-header">
    <a href="/" class="back-link">← Back to home</a>
    <h1 class="canvas-title"><%= canvas.theme %></h1>
    <div class="canvas-meta">
      <div class="stat">
        <span class="label">Contributions:</span>
        <span class="value" id="contribution-count"><%= canvas.contributionCount %></span>
      </div>
      <div class="stat">
        <span class="label">Marks:</span>
        <span class="value" id="mark-count"><%= markCount %></span>
      </div>
      <% if (canvas.status === 'active') { %>
        <div class="stat">
          <span class="label">Status:</span>
          <span class="value" style="color: #4ade80;">Active</span>
        </div>
      <% } else { %>
        <div class="stat">
          <span class="label">Status:</span>
          <span class="value" style="color: #888;">Archived</span>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Canvas viewer -->
  <div class="canvas-viewer">
    <div class="view-toggle">
      <button id="btn-live" class="active" onclick="switchView('live')">Live</button>
      <button id="btn-rendered" onclick="switchView('rendered')">Rendered</button>
    </div>
    
    <div class="canvas-content">
      <!-- Rendered view -->
      <% if (canvas.renderUrl) { %>
        <img id="rendered-view" src="<%= canvas.renderUrl %>" alt="<%= canvas.theme %> - Rendered" />
      <% } else { %>
        <div id="rendered-view" class="no-render-message">
          <p>No render yet. First render after 25 contributions.</p>
        </div>
      <% } %>
      
      <!-- Live primitive view -->
      <canvas id="live-view" class="active"></canvas>
    </div>
  </div>

  <!-- Contribute section -->
  <% if (canvas.status === 'active') { %>
    <div class="canvas-actions">
      <div class="contribute-card">
        <h3>Contribute to this Canvas — $2</h3>
        <p>Your contribution adds 1-5 marks to the canvas, generated by AI based on your optional seed word. Watch your contribution appear live, then see it incorporated into the next rendered artwork.</p>
        
        <form class="contribute-form" id="contribute-form">
          <input 
            type="email" 
            id="email-input" 
            placeholder="Your email" 
            required 
          />
          <input 
            type="text" 
            id="seed-word-input" 
            placeholder="Optional seed word (max 1 word)" 
            maxlength="20" 
          />
          <button type="submit">Contribute $2</button>
        </form>
      </div>
      
      <div class="progress-card">
        <h3>Next Render</h3>
        <div class="progress-bar">
          <div class="progress-fill" id="progress-fill" style="width: <%= ((canvas.contributionCount % 25) / 25 * 100) %>%;"></div>
        </div>
        <p class="progress-label"><span id="progress-text"><%= canvas.contributionCount % 25 %> / 25</span> contributions</p>
        <p style="margin-top: 16px; font-size: 13px; color: #666; line-height: 1.5;">
          Every 25 contributions, we generate a new AI-rendered artwork based on all the primitives. Your marks become part of the art.
        </p>
      </div>
    </div>
  <% } %>

  <!-- Contributors & Renders -->
  <div class="canvas-info">
    <div class="info-section">
      <h3>Recent Contributors</h3>
      <div class="contributor-list" id="contributor-list">
        <% if (contributors.length === 0) { %>
          <div class="empty-state">No contributions yet. Be the first!</div>
        <% } else { %>
          <% contributors.slice(0, 20).forEach(c => { %>
            <div class="contributor-item">
              <span class="contributor-email"><%= c.user_email || 'Anonymous' %></span>
              <span class="contributor-time"><%= new Date(c.created_at).toLocaleDateString() %></span>
            </div>
          <% }); %>
        <% } %>
      </div>
    </div>
    
    <div class="info-section">
      <h3>Render History</h3>
      <div class="render-gallery" id="render-gallery">
        <% if (renders.length === 0) { %>
          <div class="empty-state">No renders yet. First at 25 contributions.</div>
        <% } else { %>
          <% renders.forEach(r => { %>
            <div class="render-thumbnail" onclick="viewRender('<%= r.image_path %>')">
              <img src="<%= r.image_path %>" alt="Render at <%= r.contribution_count_at %> contributions" />
            </div>
          <% }); %>
        <% } %>
      </div>
    </div>
  </div>
</div>

<script>
const canvasId = '<%= canvas.id %>';
let currentView = 'live';

// View toggle
function switchView(view) {
  currentView = view;
  document.getElementById('btn-live').classList.toggle('active', view === 'live');
  document.getElementById('btn-rendered').classList.toggle('active', view === 'rendered');
  document.getElementById('live-view').classList.toggle('active', view === 'live');
  document.getElementById('rendered-view').classList.toggle('active', view === 'rendered');
}

// Render live primitive canvas
const liveCanvas = document.getElementById('live-view');
const ctx = liveCanvas.getContext('2d');

function resizeCanvas() {
  const container = liveCanvas.parentElement;
  liveCanvas.width = container.offsetWidth;
  liveCanvas.height = container.offsetHeight;
  renderLiveView();
}

async function renderLiveView() {
  const res = await fetch(`/api/marks?canvasId=${canvasId}`);
  const marks = await res.json();
  
  const W = liveCanvas.width;
  const H = liveCanvas.height;
  
  ctx.fillStyle = '#0a0a0a';
  ctx.fillRect(0, 0, W, H);
  
  if (marks.length === 0) {
    ctx.fillStyle = '#333';
    ctx.font = '14px Inter';
    ctx.textAlign = 'center';
    ctx.fillText('No marks yet', W/2, H/2);
    return;
  }
  
  // Map marks from [-500, 500] to canvas size
  const scale = Math.min(W, H) / 1000;
  const offsetX = W / 2;
  const offsetY = H / 2;
  
  const toX = (x) => x * scale + offsetX;
  const toY = (y) => y * scale + offsetY;
  
  for (const m of marks) {
    const x = toX(m.x);
    const y = toY(m.y);
    const size = m.size * scale;
    const opacity = m.effectiveOpacity || m.opacity || 0.8;
    
    ctx.globalAlpha = opacity;
    
    switch (m.type) {
      case 'dot':
        ctx.fillStyle = m.color;
        ctx.beginPath();
        ctx.arc(x, y, size / 2, 0, Math.PI * 2);
        ctx.fill();
        break;
      
      case 'line':
        const meta = typeof m.meta === 'object' ? m.meta : JSON.parse(m.meta || '{}');
        if (meta.x2 != null) {
          ctx.strokeStyle = m.color;
          ctx.lineWidth = size;
          ctx.lineCap = 'round';
          ctx.beginPath();
          ctx.moveTo(x, y);
          ctx.lineTo(toX(meta.x2), toY(meta.y2));
          ctx.stroke();
        }
        break;
      
      case 'text':
        if (m.text) {
          ctx.fillStyle = m.color;
          ctx.font = `${size}px monospace`;
          ctx.textAlign = 'center';
          ctx.textBaseline = 'middle';
          ctx.fillText(m.text, x, y);
        }
        break;
      
      case 'arc':
        const arcMeta = typeof m.meta === 'object' ? m.meta : JSON.parse(m.meta || '{}');
        const radius = (arcMeta.radius || 30) * scale;
        ctx.strokeStyle = m.color;
        ctx.lineWidth = size;
        ctx.lineCap = 'round';
        ctx.beginPath();
        ctx.arc(x, y, radius, arcMeta.startAngle || 0, arcMeta.endAngle || Math.PI);
        ctx.stroke();
        break;
    }
  }
  
  ctx.globalAlpha = 1.0;
}

window.addEventListener('resize', resizeCanvas);
resizeCanvas();

// Contribute form
const contributeForm = document.getElementById('contribute-form');
if (contributeForm) {
  contributeForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const email = document.getElementById('email-input').value;
    const seedWord = document.getElementById('seed-word-input').value.trim().split(/\s+/)[0] || ''; // Take first word only
    
    if (!email) {
      alert('Email required');
      return;
    }
    
    contributeForm.querySelector('button').disabled = true;
    contributeForm.querySelector('button').textContent = 'Processing...';
    
    try {
      // Step 1: Create or get user
      const userRes = await fetch('/api/users', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      const user = await userRes.json();
      
      // Step 2: Check credits — if 0, redirect to Stripe
      if (user.credits < 1) {
        // Create Stripe checkout session
        const checkoutRes = await fetch('/api/stripe/create-checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ userId: user.id, type: 'single' }),
        });
        const checkout = await checkoutRes.json();
        
        if (checkout.url) {
          // Redirect to Stripe
          window.location.href = checkout.url;
        } else {
          alert('Payment setup failed. Please try again.');
        }
        return;
      }
      
      // Step 3: Make contribution
      const contributeRes = await fetch(`/api/canvas/${canvasId}/contribute`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId: user.id, seedWord: seedWord || undefined }),
      });
      
      if (!contributeRes.ok) {
        const error = await contributeRes.json();
        alert(error.error || 'Contribution failed');
        return;
      }
      
      const result = await contributeRes.json();
      
      // Success! Update UI
      alert(`Contribution successful! ${result.creditsRemaining} credits remaining.`);
      
      // Reload to show new marks
      window.location.reload();
      
    } catch (err) {
      console.error(err);
      alert('An error occurred. Please try again.');
    } finally {
      contributeForm.querySelector('button').disabled = false;
      contributeForm.querySelector('button').textContent = 'Contribute $2';
    }
  });
}

// View render in lightbox
function viewRender(imagePath) {
  // For now, just open in new tab — we can add a lightbox later
  window.open(imagePath, '_blank');
}

// WebSocket for live updates
const ws = new WebSocket(`ws://${window.location.host}?canvas=${canvasId}`);

ws.onmessage = (event) => {
  const msg = JSON.parse(event.data);
  
  if (msg.type === 'mark:created' && msg.mark.canvasId === canvasId) {
    // Re-render live view with new mark
    renderLiveView();
    
    // Update stats
    const markCount = document.getElementById('mark-count');
    if (markCount) markCount.textContent = parseInt(markCount.textContent) + 1;
  }
  
  if (msg.type === 'render_complete' && msg.canvasId === canvasId) {
    // New render is available — reload the page to show it
    window.location.reload();
  }
};
</script>

<%- include('partials/foot') %>
