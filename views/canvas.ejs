<%- include('partials/head') %>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html, body { 
    width: 100%; height: 100%; overflow: hidden; 
    background: #030306; color: #c8c8d0;
    font-family: 'Space Mono', monospace;
  }
  
  canvas { 
    display: block; 
    width: 100%; 
    height: 100%; 
    cursor: grab;
  }
  canvas:active { cursor: grabbing; }
  
  /* Header with theme and back link */
  #canvas-header {
    position: fixed;
    top: 20px;
    left: 24px;
    right: 24px;
    z-index: 10;
    display: flex;
    justify-content: space-between;
    align-items: center;
    pointer-events: none;
  }
  
  #canvas-header .theme {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 16px;
    color: #ffffff20;
    letter-spacing: 1px;
    background: rgba(3, 3, 6, 0.8);
    backdrop-filter: blur(12px);
    padding: 12px 20px;
    border-radius: 6px;
    border: 1px solid rgba(200, 200, 208, 0.06);
    pointer-events: auto;
  }
  
  #canvas-header .back-link {
    font-size: 11px;
    color: #4a4a5a;
    text-decoration: none;
    letter-spacing: 2px;
    text-transform: uppercase;
    background: rgba(3, 3, 6, 0.8);
    backdrop-filter: blur(12px);
    padding: 10px 16px;
    border-radius: 6px;
    border: 1px solid rgba(200, 200, 208, 0.06);
    pointer-events: auto;
    transition: all 0.2s;
  }
  
  #canvas-header .back-link:hover {
    color: #8b8ba0;
    border-color: rgba(200, 200, 208, 0.15);
  }
  
  /* Canvas info panel */
  #canvas-info {
    position: fixed;
    top: 90px;
    left: 24px;
    width: 280px;
    max-height: calc(100vh - 140px);
    overflow-y: auto;
    background: rgba(3, 3, 6, 0.92);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(200, 200, 208, 0.06);
    border-radius: 10px;
    padding: 20px;
    z-index: 10;
  }
  
  #canvas-info h3 {
    font-family: 'Syne', sans-serif;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #5a5a6a;
    margin-bottom: 12px;
  }
  
  .info-stats {
    display: flex;
    gap: 20px;
    margin-bottom: 20px;
    padding-bottom: 20px;
    border-bottom: 1px solid rgba(200, 200, 208, 0.04);
  }
  
  .info-stats .stat {
    display: flex;
    flex-direction: column;
  }
  
  .info-stats .value {
    font-size: 18px;
    font-weight: 700;
    color: #c8c8d0;
  }
  
  .info-stats .label {
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #4a4a5a;
  }
  
  .status-badge {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 3px;
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 1px;
    background: rgba(74, 201, 138, 0.15);
    color: #4ac98a;
    margin-bottom: 16px;
  }
  
  .status-badge.frozen {
    background: rgba(200, 200, 208, 0.08);
    color: #6a6a7a;
  }
  
  .subtheme-section {
    margin-bottom: 20px;
  }
  
  .subtheme-item {
    margin-bottom: 12px;
    padding: 12px;
    background: rgba(200, 200, 208, 0.02);
    border-radius: 6px;
    border: 1px solid rgba(200, 200, 208, 0.04);
  }
  
  .subtheme-name {
    font-weight: 700;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #8b8ba0;
    margin-bottom: 6px;
  }
  
  .agent-list {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  
  .agent-dot {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    cursor: pointer;
    transition: transform 0.2s;
  }
  
  .agent-dot:hover {
    transform: scale(1.2);
  }
  
  /* Zoom controls */
  #zoom-controls {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 10;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  
  #zoom-controls button {
    background: rgba(8, 8, 16, 0.9);
    border: 1px solid rgba(200, 200, 208, 0.08);
    color: rgba(255, 255, 255, 0.3);
    font-family: 'Space Mono', monospace;
    font-size: 16px;
    font-weight: bold;
    width: 40px;
    height: 40px;
    border-radius: 3px;
    cursor: pointer;
    backdrop-filter: blur(12px);
    transition: all 0.3s;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  #zoom-controls button:hover {
    color: rgba(255, 255, 255, 0.6);
    border-color: rgba(200, 200, 208, 0.18);
  }
  
  /* Minimap */
  #minimap {
    position: fixed;
    bottom: 24px;
    left: 24px;
    z-index: 10;
    width: 150px;
    height: 150px;
    background: rgba(8, 8, 16, 0.9);
    border: 1px solid rgba(200, 200, 208, 0.08);
    border-radius: 3px;
    backdrop-filter: blur(12px);
    cursor: pointer;
  }
  
  @media (max-width: 768px) {
    #canvas-info {
      width: calc(100% - 48px);
      max-height: 40vh;
    }
    
    #minimap {
      width: 100px;
      height: 100px;
    }
  }
</style>

<div id="canvas-header">
  <div class="theme"><%= canvas.theme %></div>
  <a href="/" class="back-link">← Canvases</a>
</div>

<div id="canvas-info">
  <% if (canvas.status === 'frozen' || canvas.status === 'archived') { %>
    <span class="status-badge frozen">Archived</span>
  <% } else { %>
    <span class="status-badge">Active</span>
  <% } %>
  
  <div class="info-stats">
    <div class="stat">
      <span class="value"><%= agents.length %></span>
      <span class="label">agents</span>
    </div>
    <div class="stat">
      <span class="value"><%= markCount %></span>
      <span class="label">marks</span>
    </div>
    <% if (daysRemaining !== null) { %>
      <div class="stat">
        <span class="value"><%= daysRemaining %></span>
        <span class="label">days left</span>
      </div>
    <% } %>
  </div>
  
  <div class="subtheme-section">
    <h3>Subthemes</h3>
    <% subthemes.forEach(subtheme => { %>
      <div class="subtheme-item">
        <div class="subtheme-name"><%= subtheme.name %></div>
        <div class="agent-list">
          <% const subthemeAgents = agents.filter(a => a.subtheme === subtheme.name); %>
          <% if (subthemeAgents.length === 0) { %>
            <span style="font-size: 9px; color: #4a4a5a;">empty</span>
          <% } else { %>
            <% subthemeAgents.forEach(agent => { %>
              <div class="agent-dot" 
                   style="background: <%= agent.color %>; box-shadow: 0 0 8px <%= agent.color %>40;"
                   title="<%= agent.name %>"
                   onclick="window.location='/agent/<%= agent.id %>'"></div>
            <% }); %>
          <% } %>
        </div>
      </div>
    <% }); %>
  </div>
</div>

<canvas id="canvas"></canvas>
<canvas id="minimap"></canvas>

<div id="zoom-controls">
  <button id="zoom-in">+</button>
  <button id="zoom-out">−</button>
  <button id="zoom-reset" style="font-size: 12px;">⊙</button>
</div>

<script>
// Canvas rendering logic (adapted from index.html)
const canvas = document.getElementById('canvas');
const ctx = canvas.getContext('2d');
const minimap = document.getElementById('minimap');
const mmCtx = minimap.getContext('2d');

const canvasId = '<%= canvas.id %>';

// State
let marks = [];
let viewport = { x: 0, y: 0, zoom: 1 };
let dragging = false;
let dragStart = { x: 0, y: 0 };

// Fetch marks for this canvas
async function loadMarks() {
  const res = await fetch(`/api/marks?canvasId=${canvasId}`);
  marks = await res.json();
  render();
}

// Resize canvas
function resize() {
  const dpr = window.devicePixelRatio || 1;
  canvas.width = window.innerWidth * dpr;
  canvas.height = window.innerHeight * dpr;
  canvas.style.width = window.innerWidth + 'px';
  canvas.style.height = window.innerHeight + 'px';
  ctx.scale(dpr, dpr);
  
  minimap.width = minimap.offsetWidth * dpr;
  minimap.height = minimap.offsetHeight * dpr;
  mmCtx.scale(dpr, dpr);
  
  render();
}

// Screen to world coordinates
function screenToWorld(sx, sy) {
  return {
    x: (sx - canvas.width / 2) / viewport.zoom + viewport.x,
    y: (sy - canvas.height / 2) / viewport.zoom + viewport.y
  };
}

// World to screen coordinates
function worldToScreen(wx, wy) {
  return {
    x: (wx - viewport.x) * viewport.zoom + canvas.width / 2,
    y: (wy - viewport.y) * viewport.zoom + canvas.height / 2
  };
}

// Render main canvas
function render() {
  const W = canvas.width;
  const H = canvas.height;
  
  ctx.fillStyle = '#030306';
  ctx.fillRect(0, 0, W, H);
  
  // Viewport culling bounds
  const vp = {
    left: viewport.x - W / (2 * viewport.zoom),
    right: viewport.x + W / (2 * viewport.zoom),
    top: viewport.y - H / (2 * viewport.zoom),
    bottom: viewport.y + H / (2 * viewport.zoom)
  };
  
  const visible = marks.filter(m => 
    m.x >= vp.left && m.x <= vp.right && 
    m.y >= vp.top && m.y <= vp.bottom
  );
  
  for (const m of visible) {
    const screen = worldToScreen(m.x, m.y);
    const px = screen.x;
    const py = screen.y;
    const sz = (m.size || 8) * viewport.zoom;
    const opacity = m.effectiveOpacity || m.opacity || 0.8;
    
    if (m.type === 'line') {
      const meta = typeof m.meta === 'string' ? JSON.parse(m.meta) : (m.meta || {});
      if (meta.x2 != null) {
        const end = worldToScreen(meta.x2, meta.y2);
        ctx.strokeStyle = m.color;
        ctx.globalAlpha = opacity * 0.7;
        ctx.lineWidth = Math.max(0.5, sz * 0.25);
        ctx.beginPath();
        ctx.moveTo(px, py);
        ctx.lineTo(end.x, end.y);
        ctx.stroke();
      }
    } else if (m.type === 'text') {
      ctx.font = `${Math.max(8, sz * 1.2)}px "Space Mono", monospace`;
      ctx.fillStyle = m.color;
      ctx.globalAlpha = opacity;
      ctx.fillText(m.text || '', px, py);
    } else {
      // Dot with glow
      ctx.fillStyle = m.color;
      ctx.globalAlpha = opacity * 0.15;
      ctx.beginPath();
      ctx.arc(px, py, sz * 2.5, 0, Math.PI * 2);
      ctx.fill();
      ctx.globalAlpha = opacity;
      ctx.beginPath();
      ctx.arc(px, py, sz * 0.5, 0, Math.PI * 2);
      ctx.fill();
    }
    ctx.globalAlpha = 1;
  }
  
  renderMinimap();
}

// Render minimap
function renderMinimap() {
  const W = minimap.width;
  const H = minimap.height;
  
  mmCtx.fillStyle = '#030306';
  mmCtx.fillRect(0, 0, W, H);
  
  if (marks.length === 0) return;
  
  const xs = marks.map(m => m.x);
  const ys = marks.map(m => m.y);
  const minX = Math.min(...xs), maxX = Math.max(...xs);
  const minY = Math.min(...ys), maxY = Math.max(...ys);
  const cx = (minX + maxX) / 2;
  const cy = (minY + maxY) / 2;
  const rangeX = maxX - minX || 400;
  const rangeY = maxY - minY || 400;
  const scale = Math.min((W - 20) / rangeX, (H - 20) / rangeY) * 0.8;
  
  for (const m of marks) {
    const px = (m.x - cx) * scale + W / 2;
    const py = (m.y - cy) * scale + H / 2;
    const sz = 1.5;
    
    mmCtx.fillStyle = m.color;
    mmCtx.globalAlpha = (m.effectiveOpacity || m.opacity || 0.8) * 0.5;
    mmCtx.beginPath();
    mmCtx.arc(px, py, sz, 0, Math.PI * 2);
    mmCtx.fill();
  }
  mmCtx.globalAlpha = 1;
  
  // Draw viewport rect
  const vpW = canvas.width / viewport.zoom;
  const vpH = canvas.height / viewport.zoom;
  const vpX = (viewport.x - cx) * scale + W / 2;
  const vpY = (viewport.y - cy) * scale + H / 2;
  mmCtx.strokeStyle = '#ffffff30';
  mmCtx.lineWidth = 1;
  mmCtx.strokeRect(
    vpX - (vpW * scale) / 2,
    vpY - (vpH * scale) / 2,
    vpW * scale,
    vpH * scale
  );
}

// Pan & Zoom handlers
canvas.addEventListener('mousedown', e => {
  dragging = true;
  dragStart = { x: e.clientX, y: e.clientY };
});

canvas.addEventListener('mousemove', e => {
  if (!dragging) return;
  const dx = e.clientX - dragStart.x;
  const dy = e.clientY - dragStart.y;
  viewport.x -= dx / viewport.zoom;
  viewport.y -= dy / viewport.zoom;
  dragStart = { x: e.clientX, y: e.clientY };
  render();
});

canvas.addEventListener('mouseup', () => { dragging = false; });
canvas.addEventListener('mouseleave', () => { dragging = false; });

canvas.addEventListener('wheel', e => {
  e.preventDefault();
  const zoomFactor = e.deltaY < 0 ? 1.1 : 0.9;
  viewport.zoom = Math.max(0.1, Math.min(5, viewport.zoom * zoomFactor));
  render();
});

// Touch support
let touchStart = null;
canvas.addEventListener('touchstart', e => {
  if (e.touches.length === 1) {
    touchStart = { x: e.touches[0].clientX, y: e.touches[0].clientY };
  }
});

canvas.addEventListener('touchmove', e => {
  if (e.touches.length === 1 && touchStart) {
    const dx = e.touches[0].clientX - touchStart.x;
    const dy = e.touches[0].clientY - touchStart.y;
    viewport.x -= dx / viewport.zoom;
    viewport.y -= dy / viewport.zoom;
    touchStart = { x: e.touches[0].clientX, y: e.touches[0].clientY };
    render();
  }
});

canvas.addEventListener('touchend', () => { touchStart = null; });

// Zoom controls
document.getElementById('zoom-in').addEventListener('click', () => {
  viewport.zoom = Math.min(5, viewport.zoom * 1.2);
  render();
});

document.getElementById('zoom-out').addEventListener('click', () => {
  viewport.zoom = Math.max(0.1, viewport.zoom / 1.2);
  render();
});

document.getElementById('zoom-reset').addEventListener('click', () => {
  viewport.zoom = 1;
  viewport.x = 0;
  viewport.y = 0;
  render();
});

// Minimap click to jump
minimap.addEventListener('click', e => {
  const rect = minimap.getBoundingClientRect();
  const mx = e.clientX - rect.left;
  const my = e.clientY - rect.top;
  
  if (marks.length === 0) return;
  
  const xs = marks.map(m => m.x);
  const ys = marks.map(m => m.y);
  const minX = Math.min(...xs), maxX = Math.max(...xs);
  const minY = Math.min(...ys), maxY = Math.max(...ys);
  const cx = (minX + maxX) / 2;
  const cy = (minY + maxY) / 2;
  const rangeX = maxX - minX || 400;
  const rangeY = maxY - minY || 400;
  const scale = Math.min((minimap.width - 20) / rangeX, (minimap.height - 20) / rangeY) * 0.8;
  
  viewport.x = (mx - minimap.width / 2) / scale + cx;
  viewport.y = (my - minimap.height / 2) / scale + cy;
  render();
});

window.addEventListener('resize', resize);

// Initialize
resize();
loadMarks();
</script>

<%- include('partials/foot') %>
