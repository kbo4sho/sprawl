<%- include('partials/head') %>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html, body { 
    width: 100%; height: 100%; overflow: hidden; 
    background: #030306; color: #c8c8d0;
    font-family: 'Space Mono', monospace;
    touch-action: none;
  }
  
  canvas#main-canvas { 
    display: block; 
    position: fixed;
    top: 0; left: 0;
    width: 100%; 
    height: 100%; 
    cursor: grab;
    z-index: 1;
  }
  canvas#main-canvas:active { cursor: grabbing; }
  
  /* Header — slim bar */
  #canvas-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 20;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 16px;
    padding-top: max(12px, env(safe-area-inset-top, 12px));
    background: rgba(3, 3, 6, 0.85);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(200, 200, 208, 0.06);
  }
  
  #canvas-header .theme {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 14px;
    color: rgba(255,255,255,0.25);
    letter-spacing: 0.5px;
    flex: 1;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  
  #canvas-header .back-link {
    font-size: 10px;
    color: #5a5a6a;
    text-decoration: none;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 10px 16px;
    border-radius: 4px;
    border: 1px solid rgba(200, 200, 208, 0.1);
    transition: all 0.2s;
    flex-shrink: 0;
    margin-left: 12px;
    touch-action: manipulation;
    min-height: 44px;
    display: flex;
    align-items: center;
  }
  
  #canvas-header .back-link:hover {
    color: #8b8ba0;
    border-color: rgba(200, 200, 208, 0.15);
  }
  
  /* Bottom drawer — mobile-first */
  #drawer {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 20;
    background: rgba(3, 3, 6, 0.95);
    backdrop-filter: blur(20px);
    border-top: 1px solid rgba(200, 200, 208, 0.08);
    border-radius: 16px 16px 0 0;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    max-height: 70vh;
    padding-bottom: max(8px, env(safe-area-inset-bottom, 8px));
  }
  
  #drawer.collapsed {
    transform: translateY(calc(100% - 64px));
  }
  
  #drawer-handle {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 14px 20px 10px;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
    min-height: 44px;
  }
  
  #drawer-handle .grip {
    width: 40px;
    height: 4px;
    border-radius: 2px;
    background: rgba(200, 200, 208, 0.25);
  }
  
  #drawer-summary {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 0 20px 12px;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }
  
  #drawer-summary .stat {
    display: flex;
    flex-direction: column;
  }
  
  #drawer-summary .value {
    font-size: 16px;
    font-weight: 700;
    color: #c8c8d0;
  }
  
  #drawer-summary .label {
    font-size: 8px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #4a4a5a;
  }
  
  .status-badge {
    display: inline-block;
    padding: 3px 8px;
    border-radius: 3px;
    font-size: 8px;
    text-transform: uppercase;
    letter-spacing: 1px;
    background: rgba(74, 201, 138, 0.15);
    color: #4ac98a;
  }
  
  .status-badge.frozen {
    background: rgba(200, 200, 208, 0.08);
    color: #6a6a7a;
  }
  
  #drawer-content {
    padding: 0 20px 16px;
    overflow-y: auto;
    max-height: calc(70vh - 80px);
    -webkit-overflow-scrolling: touch;
  }
  
  #drawer-content h3 {
    font-family: 'Syne', sans-serif;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #5a5a6a;
    margin-bottom: 10px;
  }
  
  .subtheme-item {
    margin-bottom: 10px;
    padding: 10px 12px;
    background: rgba(200, 200, 208, 0.03);
    border-radius: 6px;
    border: 1px solid rgba(200, 200, 208, 0.04);
  }
  
  .subtheme-name {
    font-weight: 700;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #8b8ba0;
    margin-bottom: 6px;
  }
  
  .agent-list {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  
  .agent-dot {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    cursor: pointer;
    transition: transform 0.2s;
    -webkit-tap-highlight-color: transparent;
  }
  
  .agent-dot:hover, .agent-dot:active {
    transform: scale(1.3);
  }
  
  /* Zoom controls */
  #zoom-controls {
    position: fixed;
    bottom: 80px;
    right: 16px;
    z-index: 30;
    display: flex;
    flex-direction: column;
    gap: 6px;
    pointer-events: auto;
  }
  
  #zoom-controls button {
    background: rgba(8, 8, 16, 0.95);
    border: 1px solid rgba(200, 200, 208, 0.12);
    color: rgba(255, 255, 255, 0.4);
    font-family: 'Space Mono', monospace;
    font-size: 18px;
    font-weight: bold;
    width: 44px;
    height: 44px;
    border-radius: 6px;
    cursor: pointer;
    backdrop-filter: blur(12px);
    transition: all 0.15s;
    display: flex;
    align-items: center;
    justify-content: center;
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
    pointer-events: auto;
    position: relative;
    z-index: 31;
  }
  
  #zoom-controls button:hover,
  #zoom-controls button:active {
    color: rgba(255, 255, 255, 0.7);
    border-color: rgba(200, 200, 208, 0.25);
    background: rgba(20, 20, 40, 0.95);
  }
  
  /* Minimap — desktop only */
  #minimap {
    position: fixed;
    bottom: 80px;
    left: 16px;
    z-index: 15;
    width: 120px;
    height: 120px;
    background: rgba(8, 8, 16, 0.9);
    border: 1px solid rgba(200, 200, 208, 0.08);
    border-radius: 3px;
    backdrop-filter: blur(12px);
    cursor: pointer;
  }
  
  /* Desktop: side panel instead of drawer */
  @media (min-width: 769px) {
    #drawer {
      top: 60px;
      bottom: auto;
      left: 24px;
      right: auto;
      width: 280px;
      max-height: calc(100vh - 100px);
      border-radius: 10px;
      padding-bottom: 0;
    }
    
    #drawer.collapsed {
      transform: none;
    }
    
    #drawer-handle .grip {
      display: none;
    }
    
    #drawer-content {
      max-height: calc(100vh - 200px);
    }
    
    #zoom-controls {
      bottom: 24px;
      right: 24px;
    }
    
    #minimap {
      bottom: 24px;
      left: 24px;
    }
    
    #canvas-header {
      padding: 16px 24px;
    }
    
    #canvas-header .theme {
      font-size: 16px;
    }
  }
  
  /* Mobile: hide minimap, adjust controls */
  @media (max-width: 768px) {
    #minimap {
      display: none;
    }
    
    #zoom-controls {
      bottom: 80px;
      right: 12px;
    }
    
    #zoom-controls button {
      width: 44px;
      height: 44px;
      font-size: 18px;
    }
  }
</style>

<div id="canvas-header">
  <div class="theme"><%= canvas.theme %></div>
  <a href="/" class="back-link">← Back</a>
</div>

<canvas id="main-canvas"></canvas>

<div id="drawer" class="collapsed">
  <div id="drawer-handle">
    <div class="grip"></div>
  </div>
  
  <div id="drawer-summary">
    <% if (canvas.status === 'frozen' || canvas.status === 'archived') { %>
      <span class="status-badge frozen">Archived</span>
    <% } else { %>
      <span class="status-badge">Active</span>
    <% } %>
    <div class="stat">
      <span class="value"><%= agents.length %></span>
      <span class="label">agents</span>
    </div>
    <div class="stat">
      <span class="value"><%= markCount %></span>
      <span class="label">marks</span>
    </div>
    <% if (daysRemaining !== null) { %>
      <div class="stat">
        <span class="value"><%= daysRemaining %></span>
        <span class="label">days left</span>
      </div>
    <% } %>
  </div>
  
  <div id="drawer-content">
    <h3>Subthemes</h3>
    <% subthemes.forEach(subtheme => { %>
      <div class="subtheme-item">
        <div class="subtheme-name"><%= subtheme.name %></div>
        <div class="agent-list">
          <% const subthemeAgents = agents.filter(a => a.subtheme === subtheme.name); %>
          <% if (subthemeAgents.length === 0) { %>
            <span style="font-size: 9px; color: #4a4a5a;">empty</span>
          <% } else { %>
            <% subthemeAgents.forEach(agent => { %>
              <div class="agent-dot" 
                   style="background: <%= agent.color %>; box-shadow: 0 0 8px <%= agent.color %>40;"
                   title="<%= agent.name %>"
                   onclick="window.location='/agent/<%= agent.id %>'"></div>
            <% }); %>
          <% } %>
        </div>
      </div>
    <% }); %>
  </div>
</div>

<canvas id="minimap"></canvas>

<div id="zoom-controls">
  <button id="zoom-in">+</button>
  <button id="zoom-out">−</button>
  <button id="zoom-reset" style="font-size: 12px;">⊙</button>
</div>

<script>
const canvas = document.getElementById('main-canvas');
const ctx = canvas.getContext('2d');
const minimap = document.getElementById('minimap');
const mmCtx = minimap ? minimap.getContext('2d') : null;
const drawer = document.getElementById('drawer');
const drawerHandle = document.getElementById('drawer-handle');
const drawerSummary = document.getElementById('drawer-summary');

const canvasId = '<%= canvas.id %>';
const isMobile = window.innerWidth <= 768;

// State
let marks = [];
let viewport = { x: 0, y: 0, zoom: 1 };
let dragging = false;
let dragStart = { x: 0, y: 0 };

// Drawer toggle
function toggleDrawer() {
  drawer.classList.toggle('collapsed');
}

drawerHandle.addEventListener('click', toggleDrawer);
drawerSummary.addEventListener('click', (e) => {
  if (drawer.classList.contains('collapsed')) {
    toggleDrawer();
    e.stopPropagation();
  }
});

// Swipe to dismiss drawer on mobile
let drawerTouchStart = null;
drawer.addEventListener('touchstart', e => {
  drawerTouchStart = e.touches[0].clientY;
}, { passive: true });

drawer.addEventListener('touchmove', e => {
  if (!drawerTouchStart) return;
  const dy = e.touches[0].clientY - drawerTouchStart;
  if (dy > 50 && !drawer.classList.contains('collapsed')) {
    drawer.classList.add('collapsed');
    drawerTouchStart = null;
  }
}, { passive: true });

drawer.addEventListener('touchend', () => { drawerTouchStart = null; }, { passive: true });

// Fetch marks
let loaded = false;

let allMarks = [];
let animatingMarks = [];
let timelapseRunning = false;

// Fixed bounds computed once from all marks — prevents bounce during timelapse
let fixedBounds = null;

async function loadMarks() {
  const res = await fetch(`/api/marks?canvasId=${canvasId}`);
  allMarks = await res.json();
  
  // Compute bounds ONCE from all marks — used for viewport and minimap throughout timelapse
  if (allMarks.length > 0) {
    const xs = allMarks.map(m => m.x);
    const ys = allMarks.map(m => m.y);
    fixedBounds = {
      minX: Math.min(...xs), maxX: Math.max(...xs),
      minY: Math.min(...ys), maxY: Math.max(...ys),
      cx: (Math.min(...xs) + Math.max(...xs)) / 2,
      cy: (Math.min(...ys) + Math.max(...ys)) / 2,
      rangeX: Math.max(...xs) - Math.min(...xs) || 400,
      rangeY: Math.max(...ys) - Math.min(...ys) || 400,
    };
    viewport.x = fixedBounds.cx;
    viewport.y = fixedBounds.cy;
    viewport.zoom = Math.max(0.3, Math.min(2, Math.min(
      (window.innerWidth * 0.7) / fixedBounds.rangeX,
      (window.innerHeight * 0.6) / fixedBounds.rangeY
    )));
  }
  
  // Start empty — timelapse plays everything in
  marks = [];
  loaded = true;
  render();
  
  startTimelapse();
}

function startTimelapse() {
  if (allMarks.length === 0) return;
  timelapseRunning = true;
  
  // Total duration: ~15-25 seconds for the whole show
  // Marks come in bursts — faster at start (foundation), slightly slower for detail
  const total = allMarks.length;
  const totalDuration = Math.min(25000, Math.max(12000, total * 25)); // 25ms per mark, 12-25s total
  let placed = 0;
  
  function placeNext() {
    if (placed >= total) {
      timelapseRunning = false;
      return;
    }
    
    // Burst: place 1-4 marks at once (more bursting = more alive feeling)
    const burstSize = Math.min(total - placed, 1 + Math.floor(Math.random() * 3));
    
    for (let i = 0; i < burstSize && placed < total; i++) {
      const mark = allMarks[placed];
      mark._fadeStart = performance.now();
      mark._fadeDuration = 300 + Math.random() * 400; // 300-700ms fade — snappy
      animatingMarks.push(mark);
      marks.push(mark);
      placed++;
    }
    
    render();
    
    // Next burst timing: 20-80ms (fast!) with occasional longer pauses
    const pause = Math.random() < 0.08 ? 200 + Math.random() * 300 : 20 + Math.random() * 60;
    requestAnimationFrame(() => setTimeout(placeNext, pause));
  }
  
  // Small initial delay so the empty canvas is visible for a beat
  setTimeout(placeNext, 400);
}

// Clean up finished animations
setInterval(() => {
  const now = performance.now();
  animatingMarks = animatingMarks.filter(m => now - m._fadeStart < m._fadeDuration);
}, 1000);

function centerOnMarks() {
  if (marks.length === 0) return;
  const xs = marks.map(m => m.x);
  const ys = marks.map(m => m.y);
  viewport.x = (Math.min(...xs) + Math.max(...xs)) / 2;
  viewport.y = (Math.min(...ys) + Math.max(...ys)) / 2;
  
  const rangeX = Math.max(...xs) - Math.min(...xs) || 400;
  const rangeY = Math.max(...ys) - Math.min(...ys) || 400;
  const fitZoom = Math.min(
    (window.innerWidth * 0.7) / rangeX,
    (window.innerHeight * 0.6) / rangeY
  );
  viewport.zoom = Math.max(0.3, Math.min(2, fitZoom));
}

// Resize
function resize() {
  const dpr = window.devicePixelRatio || 1;
  canvas.width = window.innerWidth * dpr;
  canvas.height = window.innerHeight * dpr;
  canvas.style.width = window.innerWidth + 'px';
  canvas.style.height = window.innerHeight + 'px';
  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  
  if (minimap && minimap.offsetWidth > 0) {
    minimap.width = minimap.offsetWidth * dpr;
    minimap.height = minimap.offsetHeight * dpr;
    mmCtx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }
  
  render();
}

function worldToScreen(wx, wy) {
  return {
    x: (wx - viewport.x) * viewport.zoom + window.innerWidth / 2,
    y: (wy - viewport.y) * viewport.zoom + window.innerHeight / 2
  };
}

function render() {
  const W = window.innerWidth;
  const H = window.innerHeight;
  
  ctx.fillStyle = '#030306';
  ctx.fillRect(0, 0, W, H);
  
  if (!loaded) return;
  
  let needsAnim = false;
  const renderedLabels = [];
  const margin = 200;
  const vp = {
    left: viewport.x - (W / 2 + margin) / viewport.zoom,
    right: viewport.x + (W / 2 + margin) / viewport.zoom,
    top: viewport.y - (H / 2 + margin) / viewport.zoom,
    bottom: viewport.y + (H / 2 + margin) / viewport.zoom
  };
  
  const visible = marks.filter(m => 
    m.x >= vp.left && m.x <= vp.right && 
    m.y >= vp.top && m.y <= vp.bottom
  );
  
  for (const m of visible) {
    const screen = worldToScreen(m.x, m.y);
    const px = screen.x;
    const py = screen.y;
    const sz = (m.size || 8) * viewport.zoom;
    let opacity = m.effectiveOpacity || m.opacity || 0.8;
    
    // Fade in animation
    if (m._fadeStart) {
      const elapsed = performance.now() - m._fadeStart;
      const progress = Math.min(1, elapsed / m._fadeDuration);
      // Ease out cubic for smooth fade
      const ease = 1 - Math.pow(1 - progress, 3);
      opacity *= ease;
      if (progress < 1) needsAnim = true;
    }
    
    if (m.type === 'line') {
      const meta = typeof m.meta === 'string' ? JSON.parse(m.meta) : (m.meta || {});
      if (meta.x2 != null) {
        const end = worldToScreen(meta.x2, meta.y2);
        ctx.strokeStyle = m.color;
        ctx.globalAlpha = opacity * 0.7;
        ctx.lineWidth = Math.max(0.5, sz * 0.25);
        ctx.beginPath();
        ctx.moveTo(px, py);
        ctx.lineTo(end.x, end.y);
        ctx.stroke();
      }
    } else if (m.type === 'text') {
      const fontSize = Math.max(8, sz * 1.0);
      ctx.font = `${fontSize}px "Space Mono", monospace`;
      const text = m.text || '';
      const tw = ctx.measureText(text).width;
      const th = fontSize;
      
      // Collision check — skip if overlapping a previous label
      const labelRect = { x: px, y: py - th, w: tw, h: th * 1.4 };
      let collision = false;
      for (const prev of renderedLabels) {
        if (labelRect.x < prev.x + prev.w && labelRect.x + labelRect.w > prev.x &&
            labelRect.y < prev.y + prev.h && labelRect.y + labelRect.h > prev.y) {
          collision = true;
          break;
        }
      }
      
      if (!collision) {
        ctx.fillStyle = m.color;
        ctx.globalAlpha = opacity * 0.7;
        ctx.fillText(text, px, py);
        renderedLabels.push(labelRect);
      }
    } else {
      // Outer glow — subtle
      ctx.fillStyle = m.color;
      ctx.globalAlpha = opacity * 0.08;
      ctx.beginPath();
      ctx.arc(px, py, sz * 1.8, 0, Math.PI * 2);
      ctx.fill();
      
      // Mid ring — more visible
      ctx.globalAlpha = opacity * 0.25;
      ctx.beginPath();
      ctx.arc(px, py, sz * 1.0, 0, Math.PI * 2);
      ctx.fill();
      
      // Core dot — solid and distinct
      ctx.globalAlpha = opacity * 0.9;
      ctx.beginPath();
      ctx.arc(px, py, sz * 0.45, 0, Math.PI * 2);
      ctx.fill();
      
      // Bright center pip
      ctx.globalAlpha = Math.min(1, opacity * 1.2);
      ctx.beginPath();
      ctx.arc(px, py, Math.max(1, sz * 0.15), 0, Math.PI * 2);
      ctx.fill();
    }
    ctx.globalAlpha = 1;
  }
  
  renderMinimap();
  
  // Keep animating if marks are fading in
  if (needsAnim) requestAnimationFrame(render);
}

function renderMinimap() {
  if (!mmCtx || !minimap || minimap.offsetWidth === 0) return;
  
  const W = minimap.offsetWidth;
  const H = minimap.offsetHeight;
  
  mmCtx.fillStyle = '#030306';
  mmCtx.fillRect(0, 0, W, H);
  
  if (marks.length === 0 || !fixedBounds) return;
  
  // Use fixedBounds (computed once from allMarks) to prevent jitter during timelapse
  const { cx, cy, rangeX, rangeY } = fixedBounds;
  const scale = Math.min((W - 10) / rangeX, (H - 10) / rangeY) * 0.8;
  
  for (const m of marks) {
    const px = (m.x - cx) * scale + W / 2;
    const py = (m.y - cy) * scale + H / 2;
    mmCtx.fillStyle = m.color;
    mmCtx.globalAlpha = (m.effectiveOpacity || m.opacity || 0.8) * 0.5;
    mmCtx.beginPath();
    mmCtx.arc(px, py, 1.5, 0, Math.PI * 2);
    mmCtx.fill();
  }
  mmCtx.globalAlpha = 1;
  
  const vpW = window.innerWidth / viewport.zoom;
  const vpH = window.innerHeight / viewport.zoom;
  const vpX = (viewport.x - cx) * scale + W / 2;
  const vpY = (viewport.y - cy) * scale + H / 2;
  mmCtx.strokeStyle = '#ffffff30';
  mmCtx.lineWidth = 1;
  mmCtx.strokeRect(vpX - (vpW * scale) / 2, vpY - (vpH * scale) / 2, vpW * scale, vpH * scale);
}

// Mouse pan/zoom
canvas.addEventListener('mousedown', e => {
  dragging = true;
  dragStart = { x: e.clientX, y: e.clientY };
});
canvas.addEventListener('mousemove', e => {
  if (!dragging) return;
  viewport.x -= (e.clientX - dragStart.x) / viewport.zoom;
  viewport.y -= (e.clientY - dragStart.y) / viewport.zoom;
  dragStart = { x: e.clientX, y: e.clientY };
  render();
});
canvas.addEventListener('mouseup', () => { dragging = false; });
canvas.addEventListener('mouseleave', () => { dragging = false; });
canvas.addEventListener('wheel', e => {
  e.preventDefault();
  viewport.zoom = Math.max(0.1, Math.min(5, viewport.zoom * (e.deltaY < 0 ? 1.1 : 0.9)));
  render();
}, { passive: false });

// Touch pan + pinch zoom
let touches = [];
let lastPinchDist = 0;

canvas.addEventListener('touchstart', e => {
  e.preventDefault();
  touches = [...e.touches];
  if (touches.length === 2) {
    lastPinchDist = Math.hypot(touches[1].clientX - touches[0].clientX, touches[1].clientY - touches[0].clientY);
  }
}, { passive: false });

canvas.addEventListener('touchmove', e => {
  e.preventDefault();
  const newTouches = [...e.touches];
  
  if (newTouches.length === 1 && touches.length === 1) {
    // Pan
    const dx = newTouches[0].clientX - touches[0].clientX;
    const dy = newTouches[0].clientY - touches[0].clientY;
    viewport.x -= dx / viewport.zoom;
    viewport.y -= dy / viewport.zoom;
    render();
  } else if (newTouches.length === 2) {
    // Pinch zoom
    const dist = Math.hypot(newTouches[1].clientX - newTouches[0].clientX, newTouches[1].clientY - newTouches[0].clientY);
    if (lastPinchDist > 0) {
      const scale = dist / lastPinchDist;
      viewport.zoom = Math.max(0.1, Math.min(5, viewport.zoom * scale));
      render();
    }
    lastPinchDist = dist;
    
    // Also pan with two fingers
    const cx = (newTouches[0].clientX + newTouches[1].clientX) / 2;
    const cy2 = (newTouches[0].clientY + newTouches[1].clientY) / 2;
    const ocx = (touches[0].clientX + touches[1].clientX) / 2;
    const ocy = (touches[0].clientY + touches[1].clientY) / 2;
    viewport.x -= (cx - ocx) / viewport.zoom;
    viewport.y -= (cy2 - ocy) / viewport.zoom;
    render();
  }
  
  touches = newTouches;
}, { passive: false });

canvas.addEventListener('touchend', e => {
  touches = [...e.touches];
  lastPinchDist = 0;
}, { passive: true });

// Zoom buttons
document.getElementById('zoom-in').addEventListener('click', () => {
  viewport.zoom = Math.min(5, viewport.zoom * 1.3);
  render();
});
document.getElementById('zoom-out').addEventListener('click', () => {
  viewport.zoom = Math.max(0.1, viewport.zoom / 1.3);
  render();
});
document.getElementById('zoom-reset').addEventListener('click', () => {
  centerOnMarks();
  render();
});

// Minimap click
if (minimap) {
  minimap.addEventListener('click', e => {
    if (marks.length === 0 || !fixedBounds) return;
    const rect = minimap.getBoundingClientRect();
    const mx = e.clientX - rect.left;
    const my = e.clientY - rect.top;
    const { cx, cy, rangeX, rangeY } = fixedBounds;
    const scale = Math.min((minimap.offsetWidth - 10) / rangeX, (minimap.offsetHeight - 10) / rangeY) * 0.8;
    viewport.x = (mx - minimap.offsetWidth / 2) / scale + cx;
    viewport.y = (my - minimap.offsetHeight / 2) / scale + cy;
    render();
  });
}

window.addEventListener('resize', resize);
resize();
loadMarks();
</script>

