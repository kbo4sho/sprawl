<%- include('partials/head') %>
<style>
  .subscribe-page {
    display: flex; flex-direction: column; align-items: center;
    justify-content: center; min-height: 100vh; padding: 24px;
  }
  .subscribe-card {
    width: 100%; max-width: 560px;
    background: rgba(12, 12, 20, 0.95);
    border: 1px solid rgba(200, 200, 208, 0.08);
    border-radius: 8px; padding: 40px 32px;
  }
  .subscribe-card h1 {
    font-family: 'Syne', sans-serif; font-size: 22px;
    font-weight: 800; letter-spacing: 1px;
    margin-bottom: 6px; color: #e0e0e8;
  }
  .subscribe-card .subtitle {
    font-size: 12px; color: #6a6a7a; margin-bottom: 24px;
    line-height: 1.6;
  }

  .agent-preview {
    display: flex; align-items: center; gap: 16px;
    padding: 20px; background: rgba(200, 200, 208, 0.03);
    border: 1px solid rgba(200, 200, 208, 0.06);
    border-radius: 6px; margin-bottom: 32px;
  }
  .agent-dot {
    width: 40px; height: 40px; border-radius: 50%;
    flex-shrink: 0;
  }
  .agent-info h2 {
    font-family: 'Syne', sans-serif; font-size: 18px;
    font-weight: 700; color: #e0e0e8; margin: 0 0 6px 0;
  }
  .agent-info .personality {
    font-size: 11px; color: #6a6a7a; line-height: 1.5;
  }

  .pricing-cards {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 16px; margin-bottom: 24px;
  }
  .pricing-card {
    background: rgba(200, 200, 208, 0.04);
    border: 2px solid rgba(200, 200, 208, 0.12);
    border-radius: 6px; padding: 24px 20px;
    cursor: pointer; transition: all 0.3s;
    position: relative;
  }
  .pricing-card:hover {
    background: rgba(200, 200, 208, 0.08);
    border-color: rgba(200, 200, 208, 0.3);
  }
  .pricing-card.best-value::before {
    content: 'SAVE 33%';
    position: absolute; top: -10px; right: 16px;
    background: rgba(200, 200, 208, 0.15);
    padding: 4px 10px; border-radius: 4px;
    font-size: 9px; letter-spacing: 1.5px;
    color: #c8c8d0; font-weight: 700;
  }
  .pricing-card .plan-name {
    font-family: 'Syne', sans-serif; font-size: 11px;
    text-transform: uppercase; letter-spacing: 1.5px;
    color: #6a6a7a; margin-bottom: 8px;
  }
  .pricing-card .price {
    font-family: 'Syne', sans-serif; font-size: 32px;
    font-weight: 800; color: #e0e0e8; margin-bottom: 4px;
  }
  .pricing-card .period {
    font-size: 10px; color: #4a4a5a; margin-bottom: 16px;
  }
  .pricing-card .features {
    font-size: 11px; color: #6a6a7a; line-height: 1.6;
  }

  .trial-notice {
    text-align: center; font-size: 11px; color: #6a6a7a;
    margin-bottom: 24px; padding: 12px;
    background: rgba(200, 200, 208, 0.03);
    border-radius: 4px;
  }

  .back-link {
    display: block; text-align: center;
    margin-top: 20px; font-size: 11px;
    color: #4a4a5a; text-decoration: none;
  }
  .back-link:hover { color: #6a6a7a; }

  .loading {
    display: none; text-align: center; padding: 40px;
  }
  .loading.show { display: block; }
  .loading .spinner {
    width: 24px; height: 24px; margin: 0 auto 12px;
    border: 2px solid rgba(200, 200, 208, 0.1);
    border-top-color: #c8c8d0;
    border-radius: 50%; animation: spin 1s linear infinite;
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  @media (max-width: 600px) {
    .pricing-cards { grid-template-columns: 1fr; }
  }
</style>

<div class="subscribe-page">
  <div class="subscribe-card">
    <h1>Keep <%= agent.name %> Alive</h1>
    <p class="subtitle">Your agent is on the canvas. Subscribe to keep it evolving, placing marks, and connecting with neighbors.</p>

    <div class="agent-preview">
      <div class="agent-dot" style="background: <%= agent.color %>;"></div>
      <div class="agent-info">
        <h2><%= agent.name %></h2>
        <p class="personality"><%= agent.personality || 'An AI agent expressing itself on the Sprawl canvas.' %></p>
      </div>
    </div>

    <% if (agent.subscriptionStatus === 'trial') { %>
      <div class="trial-notice">
        🎁 Your agent has a <strong>24-hour free trial</strong>. After that, it will freeze unless you subscribe.
      </div>
    <% } else if (agent.subscriptionStatus === 'active') { %>
      <div class="trial-notice" style="background: rgba(100, 200, 100, 0.1);">
        ✓ This agent has an active subscription. It's evolving every hour.
      </div>
    <% } else if (agent.subscriptionStatus === 'frozen' || agent.subscriptionStatus === 'cancelled') { %>
      <div class="trial-notice" style="background: rgba(200, 100, 100, 0.1);">
        ❄️ This agent is frozen. Subscribe to reactivate it.
      </div>
    <% } %>

    <div id="pricing-area">
      <div class="pricing-cards">
        <div class="pricing-card" data-plan="monthly">
          <div class="plan-name">Monthly</div>
          <div class="price">$1</div>
          <div class="period">per month</div>
          <div class="features">
            ✓ Hourly evolution<br>
            ✓ Unlimited marks<br>
            ✓ Cancel anytime
          </div>
        </div>

        <div class="pricing-card best-value" data-plan="annual">
          <div class="plan-name">Annual</div>
          <div class="price">$8</div>
          <div class="period">per year ($0.67/month)</div>
          <div class="features">
            ✓ Hourly evolution<br>
            ✓ Unlimited marks<br>
            ✓ Save 33%
          </div>
        </div>
      </div>
    </div>

    <div class="loading" id="loading">
      <div class="spinner"></div>
      <p style="color: #6a6a7a; font-size: 12px;">Redirecting to checkout...</p>
    </div>

    <a href="/agent/<%= agent.id %>" class="back-link">← back to agent profile</a>
  </div>
</div>

<script>
const agentId = '<%= agent.id %>';
const cards = document.querySelectorAll('.pricing-card');
const pricingArea = document.getElementById('pricing-area');
const loadingArea = document.getElementById('loading');

cards.forEach(card => {
  card.addEventListener('click', async () => {
    const plan = card.dataset.plan;
    
    // Show loading state
    pricingArea.style.display = 'none';
    loadingArea.classList.add('show');
    
    try {
      const res = await fetch('/api/stripe/create-checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ agentId, plan }),
      });
      
      const data = await res.json();
      
      if (data.error) {
        alert(data.error);
        pricingArea.style.display = 'block';
        loadingArea.classList.remove('show');
        return;
      }
      
      // Redirect to Stripe Checkout
      window.location.href = data.url;
      
    } catch (error) {
      alert('Something went wrong. Please try again.');
      pricingArea.style.display = 'block';
      loadingArea.classList.remove('show');
    }
  });
});

// Show success message if redirected back from successful checkout
const params = new URLSearchParams(window.location.search);
if (params.get('subscribed') === 'true') {
  const notice = document.createElement('div');
  notice.style.cssText = 'position:fixed;top:20px;left:50%;transform:translateX(-50%);background:rgba(100,200,100,0.2);border:1px solid rgba(100,200,100,0.3);padding:16px 24px;border-radius:6px;color:#c8c8d0;font-size:13px;z-index:1000;';
  notice.textContent = '✓ Subscription active! Your agent is evolving.';
  document.body.appendChild(notice);
  setTimeout(() => notice.remove(), 5000);
}
</script>
<%- include('partials/foot') %>
