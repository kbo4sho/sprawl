<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
  <title><%= experiment.premise %> — Sprawl</title>
  
  <meta property="og:title" content="<%= experiment.premise %>">
  <meta property="og:description" content="A Sprawl experiment — what happens when you ask an AI a generous question?">
  <% if (experiment.thumbnail_url) { %>
  <meta property="og:image" content="<%= experiment.thumbnail_url %>">
  <% } %>
  <meta property="og:type" content="website">
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;700;800&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body {
      width: 100%; height: 100%; overflow: hidden;
      background: #030306; color: #c8c8d0;
      font-family: 'Space Mono', monospace;
      display: flex; align-items: center; justify-content: center;
    }

    /* Letterboxed square canvas */
    #canvas-wrap {
      position: relative;
      width: 100vw; height: 100vw;
      max-height: 100vh; max-width: 100vh;
    }
    #canvas {
      position: absolute; top: 0; left: 0;
      width: 100%; height: 100%;
      cursor: crosshair; z-index: 0;
    }

    /* Overlays */
    .overlay-top-left {
      position: fixed; top: 24px; left: 28px; z-index: 10;
      max-width: 500px;
    }
    .back-link {
      display: inline-block;
      font-size: 9px; letter-spacing: 3px; text-transform: uppercase;
      color: #555560; text-decoration: none;
      margin-bottom: 16px; transition: color 0.4s;
    }
    .back-link:hover { color: #999; }
    .premise {
      font-family: 'Syne', sans-serif;
      font-weight: 700; font-size: 22px; line-height: 1.3;
      color: #ffffff15; transition: color 0.4s;
    }

    .overlay-top-right {
      position: fixed; top: 24px; right: 28px; z-index: 10;
      text-align: right;
    }
    .status-line {
      font-size: 9px; letter-spacing: 3px; text-transform: uppercase;
      color: #ffffff18; display: flex; align-items: center; gap: 8px;
      justify-content: flex-end;
    }
    .status-dot {
      width: 6px; height: 6px; border-radius: 50%; background: #ffffff20; flex-shrink: 0;
    }
    .status-dot.running, .status-dot.generating { background: #4a9eff40; animation: breathe 3s ease-in-out infinite; }
    .status-dot.ready, .status-dot.complete { background: #10b98140; }
    @keyframes breathe { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }
    .axis-tag {
      display: inline-block; margin-top: 6px;
      font-size: 8px; letter-spacing: 2px; text-transform: uppercase;
      color: #ffffff12; border: 1px solid #ffffff08; border-radius: 2px;
      padding: 3px 8px;
    }

    .overlay-bottom-left {
      position: fixed; bottom: 28px; left: 28px; z-index: 10; width: 200px;
    }
    .confidence-track { width: 100%; height: 2px; background: #ffffff06; border-radius: 1px; overflow: hidden; margin-bottom: 6px; }
    .confidence-fill { height: 100%; background: #ffffff18; transition: width 1s ease-out; }
    .confidence-meta { display: flex; justify-content: space-between; font-size: 8px; letter-spacing: 2px; text-transform: uppercase; color: #ffffff10; }

    .overlay-bottom-right {
      position: fixed; bottom: 28px; right: 28px; z-index: 10;
      max-width: 360px; text-align: right;
    }
    .reflection {
      font-size: 11px; font-style: italic; line-height: 1.6;
      color: #ffffff0c; transition: color 0.4s;
    }

    .overlay-bottom-center {
      position: fixed; bottom: 28px; left: 50%; transform: translateX(-50%);
      z-index: 10; display: flex; gap: 8px;
    }
    .share-btn {
      background: #08081090; border: 1px solid #ffffff08;
      color: #ffffff20; font-family: 'Space Mono', monospace;
      font-size: 9px; letter-spacing: 2px; text-transform: uppercase;
      padding: 8px 18px; border-radius: 3px; cursor: pointer;
      backdrop-filter: blur(12px); transition: all 0.3s;
    }
    .share-btn:hover { color: #ffffff50; border-color: #ffffff18; }

    .summary-overlay {
      position: fixed; bottom: 80px; left: 50%; transform: translateX(-50%);
      z-index: 10; max-width: 500px; width: calc(100% - 56px);
      background: #08081070; border: 1px solid #ffffff06;
      border-radius: 4px; padding: 20px 24px;
      backdrop-filter: blur(20px);
      font-size: 12px; line-height: 1.7; color: #ffffff25;
    }
    .summary-overlay h3 {
      font-family: 'Syne', sans-serif; font-weight: 700;
      font-size: 9px; letter-spacing: 4px; text-transform: uppercase;
      color: #ffffff12; margin-bottom: 10px;
    }

    body:hover .premise { color: #ffffff25; }
    body:hover .reflection { color: #ffffff18; }

    @media (max-width: 600px) {
      .premise { font-size: 16px; }
      .overlay-bottom-right { max-width: 200px; }
      .overlay-bottom-right .reflection { font-size: 10px; }
      .overlay-bottom-left { width: 140px; }
    }
  </style>
</head>
<body>

<div id="canvas-wrap">
  <canvas id="canvas"></canvas>
</div>

<!-- Overlays -->
<div class="overlay-top-left">
  <a href="/experiments" class="back-link">← experiments</a>
  <h1 class="premise"><%= experiment.premise %></h1>
</div>

<div class="overlay-top-right">
  <div class="status-line">
    <span id="status-text"><%= experiment.status === 'complete' || experiment.status === 'ready' ? 'Ready' : experiment.status === 'generating' ? 'Generating' : 'Evolving' %></span>
    <div class="status-dot <%= experiment.status %>"></div>
  </div>
  <% if (experiment.axes) {
    const axes = typeof experiment.axes === 'string' ? JSON.parse(experiment.axes) : experiment.axes;
    if (axes && axes.length > 0) { axes.forEach(axis => { %>
      <span class="axis-tag"><%= axis %></span>
  <% }); } } %>
</div>

<% if (experiment.type !== 'ask') { %>
<div class="overlay-bottom-left">
  <div class="confidence-track">
    <div class="confidence-fill" id="confidence-fill" style="width: <%= experiment.confidence * 100 %>%"></div>
  </div>
  <div class="confidence-meta">
    <span>confidence</span>
    <span id="confidence-pct"><%= Math.round(experiment.confidence * 100) %>%</span>
  </div>
</div>

<div class="overlay-bottom-right">
  <div class="reflection" id="reflection"><%= experiment.reflection || '' %></div>
</div>
<% } %>

<div class="overlay-bottom-center">
  <button class="share-btn" onclick="shareExperiment()">share</button>
</div>

<% if (experiment.summary) { %>
<div class="summary-overlay">
  <h3>What happened</h3>
  <%= experiment.summary %>
</div>
<% } %>

<script>
// ============================================================
// CONFIG
// ============================================================
const experimentType = '<%= experiment.type || "evolve" %>';
const experimentStatus = '<%= experiment.status %>';
const experimentSlug = '<%= experiment.slug %>';
const canvasId = '<%= canvas.id %>';

// ============================================================
// CANVAS
// ============================================================
const canvas = document.getElementById('canvas');
const ctx = canvas.getContext('2d');
let W, H, DPR;

function resize() {
  DPR = Math.min(window.devicePixelRatio || 1, 2);
  const rect = canvas.getBoundingClientRect();
  W = rect.width;
  H = rect.height;
  canvas.width = W * DPR;
  canvas.height = H * DPR;
  ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
}
window.addEventListener('resize', resize);
resize();

// ============================================================
// DOT STATE
// ============================================================
const DOT_COUNT = 2000;
let dots = [];
let transitioning = false;
let transitionStart = 0;
const TRANSITION_MS = 4000;
let ws = null;

function hexToRgb01(hex) {
  if (!hex || hex[0] !== '#') return [0.5, 0.5, 0.5];
  return [
    parseInt(hex.slice(1,3), 16) / 255,
    parseInt(hex.slice(3,5), 16) / 255,
    parseInt(hex.slice(5,7), 16) / 255,
  ];
}

function initDots(count) {
  dots = [];
  for (let i = 0; i < count; i++) {
    dots.push({
      x: Math.random() * W, y: Math.random() * H,
      tx: 0, ty: 0,
      r: 0.5, g: 0.5, b: 0.5,
      tr: 0.5, tg: 0.5, tb: 0.5,
      size: 2, tsize: 2,
      opacity: 0.4, topacity: 0.4,
      phase: Math.random() * Math.PI * 2,
      delay: 0,
    });
  }
}

function setTargets(targetDots) {
  // Ensure we have enough dots
  while (dots.length < targetDots.length) {
    dots.push({
      x: Math.random() * W, y: Math.random() * H,
      tx: 0, ty: 0,
      r: 0.5, g: 0.5, b: 0.5,
      tr: 0.5, tg: 0.5, tb: 0.5,
      size: 2, tsize: 2,
      opacity: 0.4, topacity: 0.4,
      phase: Math.random() * Math.PI * 2,
      delay: 0,
    });
  }

  for (let i = 0; i < dots.length; i++) {
    const src = targetDots[i % targetDots.length];
    const nx = (src.x + 400) / 800;
    const ny = (src.y + 400) / 800;
    const [r, g, b] = hexToRgb01(src.color);

    dots[i].tx = nx * W;
    dots[i].ty = ny * H;
    dots[i].tr = r;
    dots[i].tg = g;
    dots[i].tb = b;
    dots[i].tsize = Math.max((src.size || 2) * (Math.min(W, H) / 600), 1.2);
    dots[i].topacity = Math.min((src.opacity || 0.5) * 1.8, 1);

    const dx = dots[i].x - dots[i].tx;
    const dy = dots[i].y - dots[i].ty;
    dots[i].delay = Math.sqrt(dx * dx + dy * dy) / Math.max(W, H) * 800;
  }
  transitioning = true;
  transitionStart = performance.now();
}

function easeInOut(t) {
  return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
}

// ============================================================
// RENDER
// ============================================================
function render() {
  ctx.clearRect(0, 0, W, H);
  ctx.fillStyle = '#030306';
  ctx.fillRect(0, 0, W, H);

  const now = performance.now();
  const t = now * 0.001;
  let allDone = true;

  for (const dot of dots) {
    let x = dot.x, y = dot.y;
    let r = dot.r, g = dot.g, b = dot.b;
    let size = dot.size, opacity = dot.opacity;

    if (transitioning) {
      const elapsed = now - transitionStart - dot.delay;
      const progress = Math.max(0, Math.min(1, elapsed / TRANSITION_MS));
      const e = easeInOut(progress);

      x = dot.x + (dot.tx - dot.x) * e;
      y = dot.y + (dot.ty - dot.y) * e;
      r = dot.r + (dot.tr - dot.r) * e;
      g = dot.g + (dot.tg - dot.g) * e;
      b = dot.b + (dot.tb - dot.b) * e;
      size = dot.size + (dot.tsize - dot.size) * e;
      opacity = dot.opacity + (dot.topacity - dot.opacity) * e;

      if (progress < 1) allDone = false;
      if (progress >= 1) {
        dot.x = dot.tx; dot.y = dot.ty;
        dot.r = dot.tr; dot.g = dot.tg; dot.b = dot.tb;
        dot.size = dot.tsize; dot.opacity = dot.topacity;
      }
    } else {
      // Resting: gentle drift
      x += Math.sin(t * 0.3 + dot.phase) * 0.4;
      y += Math.cos(t * 0.4 + dot.phase * 1.3) * 0.3;
    }

    const ri = Math.round(r * 255), gi = Math.round(g * 255), bi = Math.round(b * 255);

    // Soft glow
    ctx.globalAlpha = opacity * 0.2;
    ctx.fillStyle = `rgb(${ri},${gi},${bi})`;
    ctx.beginPath();
    ctx.arc(x, y, size * 1.8, 0, Math.PI * 2);
    ctx.fill();

    // Body
    ctx.globalAlpha = opacity * 0.85;
    ctx.beginPath();
    ctx.arc(x, y, size, 0, Math.PI * 2);
    ctx.fill();

    // Bright core
    ctx.globalAlpha = Math.min(opacity * 1.2, 1);
    ctx.fillStyle = `rgb(${Math.min(255, ri + 60)},${Math.min(255, gi + 60)},${Math.min(255, bi + 60)})`;
    ctx.beginPath();
    ctx.arc(x, y, size * 0.4, 0, Math.PI * 2);
    ctx.fill();
  }

  ctx.globalAlpha = 1;
  if (transitioning && allDone) transitioning = false;
  requestAnimationFrame(render);
}

// ============================================================
// DATA FETCHING
// ============================================================

async function fetchExperimentData() {
  try {
    const res = await fetch(`/api/experiments/${experimentSlug}`);
    const data = await res.json();

    // Update status UI
    const statusText = document.getElementById('status-text');
    const statusDot = document.querySelector('.status-dot');
    if (data.status === 'ready' || data.status === 'complete') {
      if (statusText) statusText.textContent = 'Ready';
      if (statusDot) statusDot.className = 'status-dot ready';
    }

    // Update evolve UI
    if (experimentType !== 'ask') {
      const confFill = document.getElementById('confidence-fill');
      const confPct = document.getElementById('confidence-pct');
      const reflection = document.getElementById('reflection');
      if (confFill) confFill.style.width = `${data.confidence * 100}%`;
      if (confPct) confPct.textContent = Math.round(data.confidence * 100) + '%';
      if (reflection && data.reflection) reflection.textContent = data.reflection;
    }

    return data;
  } catch (e) {
    console.error('Fetch error:', e);
    return null;
  }
}

// ============================================================
// ASK FLOW
// ============================================================

async function setupAsk() {
  initDots(DOT_COUNT);

  // Connect WebSocket
  const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
  ws = new WebSocket(`${protocol}//${window.location.host}`);
  ws.onopen = () => ws.send(JSON.stringify({ type: 'subscribe_experiment', experimentSlug }));
  ws.onmessage = (event) => {
    const data = JSON.parse(event.data);
    if (data.type === 'experiment:ready' && data.dots) {
      setTargets(data.dots);
      const statusText = document.getElementById('status-text');
      const statusDot = document.querySelector('.status-dot');
      if (statusText) statusText.textContent = 'Ready';
      if (statusDot) statusDot.className = 'status-dot ready';
    }
  };
  ws.onclose = () => setTimeout(setupAsk, 3000);

  if (experimentStatus === 'generating') {
    // Poll until ready
    const poll = async () => {
      const data = await fetchExperimentData();
      if (data && data.status === 'ready' && data.dots) {
        setTargets(data.dots);
      } else {
        setTimeout(poll, 2000);
      }
    };
    poll();
  } else if (experimentStatus === 'ready') {
    // Show resting state briefly, then reveal
    setTimeout(async () => {
      const data = await fetchExperimentData();
      if (data && data.dots) setTargets(data.dots);
    }, 1500);
  }
}

// ============================================================
// EVOLVE FLOW
// ============================================================

async function setupEvolve() {
  // Fetch marks and convert to dot format
  try {
    const res = await fetch(`/api/marks?canvasId=${canvasId}`);
    const marks = await res.json();

    if (marks.length > 0) {
      const dotMarks = marks.filter(m => m.type === 'dot');
      initDots(Math.max(dotMarks.length, DOT_COUNT));

      const targets = dotMarks.map(m => ({
        x: m.x, y: m.y,
        color: m.color,
        size: m.size,
        opacity: m.effectiveOpacity || m.opacity || 0.8,
      }));
      setTargets(targets);
    } else {
      initDots(DOT_COUNT);
    }
  } catch (e) {
    initDots(DOT_COUNT);
  }

  // WebSocket for live updates
  const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
  ws = new WebSocket(`${protocol}//${window.location.host}`);
  ws.onopen = () => ws.send(JSON.stringify({ type: 'subscribe', canvasId }));
  ws.onmessage = () => fetchExperimentData();
  ws.onclose = () => setTimeout(setupEvolve, 3000);

  // Poll status
  setInterval(fetchExperimentData, 10000);
}

// ============================================================
// SHARE
// ============================================================

function shareExperiment() {
  const url = window.location.href;
  if (navigator.share) {
    navigator.share({ title: document.querySelector('.premise').textContent, url }).catch(() => {});
  } else {
    navigator.clipboard.writeText(url).then(() => {
      const btn = event.target;
      const orig = btn.textContent;
      btn.textContent = 'copied';
      setTimeout(() => btn.textContent = orig, 2000);
    });
  }
}

// ============================================================
// INIT
// ============================================================

if (experimentType === 'ask') {
  setupAsk();
} else {
  setupEvolve();
}
requestAnimationFrame(render);
</script>
</body>
</html>
