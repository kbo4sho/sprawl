<%- include('partials/head') %>
<style>
  .home-page {
    min-height: 100vh;
    padding: 48px 24px;
    background: #030306;
  }
  
  .home-header {
    text-align: center;
    margin-bottom: 48px;
  }
  
  .home-header h1 {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 48px;
    letter-spacing: 12px;
    text-transform: uppercase;
    color: #ffffffcc;
    margin-bottom: 8px;
  }
  
  .home-header .tagline {
    font-size: 12px;
    color: #ffffff66;
    letter-spacing: 3px;
    text-transform: uppercase;
  }
  
  .canvas-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 24px;
    max-width: 1200px;
    margin: 0 auto;
  }
  
  .canvas-card {
    background: rgba(12, 12, 20, 0.6);
    border: 1px solid rgba(200, 200, 208, 0.08);
    border-radius: 8px;
    padding: 24px;
    transition: all 0.3s;
    cursor: pointer;
  }
  
  .canvas-card:hover {
    border-color: rgba(200, 200, 208, 0.15);
    background: rgba(12, 12, 20, 0.8);
    box-shadow: 0 4px 20px rgba(200, 200, 208, 0.03);
  }
  
  .canvas-theme {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 18px;
    color: #c8c8d0;
    margin-bottom: 16px;
    letter-spacing: 0.5px;
  }
  
  .canvas-preview {
    width: 100%;
    height: 200px;
    background: #030306;
    border: 1px solid rgba(200, 200, 208, 0.06);
    border-radius: 4px;
    margin-bottom: 16px;
    position: relative;
    overflow: hidden;
  }
  
  .canvas-preview canvas {
    width: 100%;
    height: 100%;
  }
  
  .canvas-preview img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .canvas-info {
    display: flex;
    gap: 16px;
    font-size: 11px;
    color: #8b8ba0;
    margin-bottom: 12px;
  }
  
  .canvas-info .stat {
    display: flex;
    flex-direction: column;
  }
  
  .canvas-info .value {
    font-size: 16px;
    color: #c8c8d0;
    font-weight: 700;
  }
  
  .canvas-info .label {
    text-transform: uppercase;
    letter-spacing: 1px;
    font-size: 9px;
    color: #4a4a5a;
  }
  
  .canvas-actions {
    display: flex;
    gap: 8px;
  }
  
  .canvas-actions a {
    flex: 1;
    padding: 8px 16px;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    border: 1px solid rgba(200, 200, 208, 0.15);
    border-radius: 4px;
    text-decoration: none;
    color: #c8c8d0;
    font-family: 'Space Mono', monospace;
    transition: all 0.2s;
    text-align: center;
  }
  
  .canvas-actions a:hover {
    background: rgba(200, 200, 208, 0.08);
    border-color: rgba(200, 200, 208, 0.25);
  }
  
  .canvas-actions a.primary {
    background: rgba(200, 200, 208, 0.1);
  }
  
  .empty-state {
    text-align: center;
    padding: 80px 24px;
    color: #4a4a5a;
  }
  
  .empty-state h2 {
    font-size: 16px;
    margin-bottom: 8px;
    color: #6a6a7a;
  }
  
  .footer-links {
    text-align: center;
    margin-top: 48px;
    padding: 24px;
    border-top: 1px solid rgba(200, 200, 208, 0.04);
  }
  
  .footer-links a {
    color: #4a4a5a;
    text-decoration: none;
    margin: 0 16px;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
  }
  
  .footer-links a:hover {
    color: #8b8ba0;
  }

  @media (max-width: 768px) {
    .canvas-grid {
      grid-template-columns: 1fr;
    }
    
    .home-header h1 {
      font-size: 32px;
      letter-spacing: 8px;
    }
  }
</style>

<div class="home-page">
  <div class="home-header">
    <h1>SPRAWL</h1>
    <p class="tagline">Feed the AI canvas</p>
  </div>

  <% if (canvases.length === 0) { %>
    <div class="empty-state">
      <h2>No active canvases</h2>
      <p>The gardener will create a new canvas on Monday at midnight CT</p>
    </div>
  <% } else { %>
    <div class="canvas-grid">
      <% canvases.forEach(canvas => { %>
        <div class="canvas-card" onclick="window.location='/canvas/<%= canvas.id %>'">
          <h2 class="canvas-theme"><%= canvas.theme %></h2>
          
          <div class="canvas-preview">
            <% if (canvas.renderUrl) { %>
              <img src="<%= canvas.renderUrl %>" alt="<%= canvas.theme %>" />
            <% } else { %>
              <canvas id="preview-<%= canvas.id %>" data-canvas-id="<%= canvas.id %>"></canvas>
            <% } %>
          </div>
          
          <div class="canvas-info">
            <div class="stat">
              <span class="value"><%= canvas.contributionCount %></span>
              <span class="label">contributions</span>
            </div>
            <div class="stat">
              <span class="value"><%= canvas.markCount %></span>
              <span class="label">marks</span>
            </div>
            <% if (canvas.renderUrl) { %>
              <div class="stat">
                <span class="value" style="color: #4a9eff;">Rendered</span>
                <span class="label">latest</span>
              </div>
            <% } else { %>
              <div class="stat">
                <span class="value"><%= canvas.daysRemaining %></span>
                <span class="label">days left</span>
              </div>
            <% } %>
          </div>
          
          <div class="canvas-actions">
            <a href="/canvas/<%= canvas.id %>" class="primary">View Canvas</a>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>

  <div class="footer-links">
    <a href="/gallery">Gallery</a>
    <a href="/interactive">Interactive</a>
  </div>
</div>

<script>
// Render live mini-previews for canvases that don't have renders yet
async function renderPreviews() {
  const canvases = document.querySelectorAll('.canvas-preview canvas');
  
  if (canvases.length === 0) return; // All canvases have renders, nothing to draw
  
  for (const canvas of canvases) {
    const canvasId = canvas.dataset.canvasId;
    const ctx = canvas.getContext('2d');
    canvas.width = canvas.offsetWidth * 2;
    canvas.height = canvas.offsetHeight * 2;
    
    // Fetch marks for this canvas
    const res = await fetch(`/api/marks?canvasId=${canvasId}`);
    const marks = await res.json();
    
    const W = canvas.width, H = canvas.height;
    ctx.fillStyle = '#030306';
    ctx.fillRect(0, 0, W, H);
    
    if (marks.length === 0) {
      // Empty canvas message
      ctx.fillStyle = '#ffffff08';
      ctx.font = '12px "Space Mono", monospace';
      ctx.textAlign = 'center';
      ctx.fillText('No marks yet', W/2, H/2);
      continue;
    }
    
    // Calculate bounds
    const xs = marks.map(m => m.x);
    const ys = marks.map(m => m.y);
    const minX = Math.min(...xs), maxX = Math.max(...xs);
    const minY = Math.min(...ys), maxY = Math.max(...ys);
    const cx = (minX + maxX) / 2;
    const cy = (minY + maxY) / 2;
    const rangeX = maxX - minX || 400;
    const rangeY = maxY - minY || 400;
    const scale = Math.min((W - 40) / rangeX, (H - 40) / rangeY) * 0.8;
    
    // Render marks
    for (const m of marks) {
      const px = (m.x - cx) * scale + W/2;
      const py = (m.y - cy) * scale + H/2;
      const sz = (m.size || 8) * scale * 0.08;
      const opacity = m.effectiveOpacity || m.opacity || 0.8;
      
      if (m.type === 'line') {
        const meta = typeof m.meta === 'string' ? JSON.parse(m.meta) : (m.meta || {});
        if (meta.x2 != null) {
          const ex = (meta.x2 - cx) * scale + W/2;
          const ey = (meta.y2 - cy) * scale + H/2;
          ctx.strokeStyle = m.color;
          ctx.globalAlpha = opacity * 0.7;
          ctx.lineWidth = Math.max(0.5, sz * 0.3);
          ctx.beginPath();
          ctx.moveTo(px, py);
          ctx.lineTo(ex, ey);
          ctx.stroke();
        }
      } else if (m.type === 'text') {
        ctx.font = `${Math.max(6, sz * 1.2)}px "Space Mono", monospace`;
        ctx.fillStyle = m.color;
        ctx.globalAlpha = opacity;
        ctx.fillText((m.text || '').slice(0, 20), px, py);
      } else {
        // Match canvas view: 4-layer dot rendering
        ctx.fillStyle = m.color;
        ctx.globalAlpha = opacity * 0.08;
        ctx.beginPath();
        ctx.arc(px, py, sz * 1.8, 0, Math.PI * 2);
        ctx.fill();
        ctx.globalAlpha = opacity * 0.25;
        ctx.beginPath();
        ctx.arc(px, py, sz * 1.0, 0, Math.PI * 2);
        ctx.fill();
        ctx.globalAlpha = opacity * 0.9;
        ctx.beginPath();
        ctx.arc(px, py, sz * 0.45, 0, Math.PI * 2);
        ctx.fill();
        ctx.globalAlpha = Math.min(1, opacity * 1.2);
        ctx.beginPath();
        ctx.arc(px, py, Math.max(0.5, sz * 0.15), 0, Math.PI * 2);
        ctx.fill();
      }
      ctx.globalAlpha = 1;
    }
  }
}

renderPreviews();
</script>

<%- include('partials/foot') %>
